            this.engine.shake(profile.boss ? 0.85 : 0.5);
            this.engine.spawnBurst(enemyMesh.position, profile.color, profile.boss ? 44 : 30, profile.boss ? 4.4 : 3);
            this.engine.tweens.add(enemyMesh.scale, { x: 0, y: 0, z: 0 }, 0.24, Easing.linear, () => {
                this.engine.scene.remove(enemyMesh);
            });

            this.grid[enemyNode.r][enemyNode.c].entity = null;
            const entIdx = this.engine.entities.findIndex((entity) => entity === enemyObj);
            if (entIdx > -1) this.engine.entities.splice(entIdx, 1);

            if (enemyObj.hiddenRoomId) {
                const hiddenRoom = this.hiddenRooms.find((room) => room.id === enemyObj.hiddenRoomId);
