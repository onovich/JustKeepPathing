    cleanupWorkingConfig(assetKey, partKey) {
        const parts = this.workingConfig.assets[assetKey];
        const part = parts?.[partKey];
        if (!part) return;
        if (Object.keys(part.faces).length === 0 && Object.keys(part.lines).length === 0) delete parts[partKey];
        if (parts && Object.keys(parts).length === 0) delete this.workingConfig.assets[assetKey];
