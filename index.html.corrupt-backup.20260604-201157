    writeSelectionEntry(item, nextEntry) {
        const part = getAppearancePart(this.workingConfig, item.assetKey, item.partKey, true);
        if (item.kind === 'mesh') {
            const isDefault = nextEntry.color === item.defaultColor
                && nextEntry.pattern === MODEL_EDITOR_DEFAULT_FACE_PATTERN.pattern
                && nextEntry.patternColor === MODEL_EDITOR_DEFAULT_FACE_PATTERN.patternColor
                && Math.abs(nextEntry.patternScale - MODEL_EDITOR_DEFAULT_FACE_PATTERN.patternScale) < 0.001;
            if (isDefault) delete part.faces[item.index];
            else part.faces[item.index] = { ...nextEntry };
        } else {
