    updateHighlight() {
        this.clearSelectionOverlay();
        if (this.selection.length === 0) {
            return;
        }

        const a = new THREE.Vector3();
        const b = new THREE.Vector3();
        const c = new THREE.Vector3();
        const normal = new THREE.Vector3();

        for (const item of this.selection) {
            const positions = item.object.geometry.getAttribute('position');
            if (item.kind === 'mesh') {
                const start = item.index * 3;
                if (start + 2 >= positions.count) continue;
                a.fromBufferAttribute(positions, start);
                b.fromBufferAttribute(positions, start + 1);
                c.fromBufferAttribute(positions, start + 2);
                normal.copy(
                    new THREE.Vector3().subVectors(b, a).cross(new THREE.Vector3().subVectors(c, a)).normalize()
                ).multiplyScalar(0.008);
                const p0 = a.clone().add(normal);
                const p1 = b.clone().add(normal);
