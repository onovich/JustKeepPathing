            bgm: {
                enabled: rawSounds.bgm?.enabled !== undefined ? !!rawSounds.bgm.enabled : defaults.sounds.bgm.enabled,
                volume: clampSoundValue(rawSounds.bgm?.volume, 0, 0.5, defaults.sounds.bgm.volume),
                tempo: clampSoundValue(rawSounds.bgm?.tempo, 50, 180, defaults.sounds.bgm.tempo),
                root: Math.round(clampSoundValue(rawSounds.bgm?.root, 30, 72, defaults.sounds.bgm.root)),
                kernel: Object.prototype.hasOwnProperty.call(BGM_KERNELS, rawSounds.bgm?.kernel) ? rawSounds.bgm.kernel : defaults.sounds.bgm.kernel,
                brightness: clampSoundValue(rawSounds.bgm?.brightness, 0.15, 1, defaults.sounds.bgm.brightness),
                swing: clampSoundValue(rawSounds.bgm?.swing, 0, 0.45, defaults.sounds.bgm.swing),
                noteLength: clampSoundValue(rawSounds.bgm?.noteLength, 0.2, 1.4, defaults.sounds.bgm.noteLength),
                attack: clampSoundValue(rawSounds.bgm?.attack, 0.001, 0.2, defaults.sounds.bgm.attack),
                release: clampSoundValue(rawSounds.bgm?.release, 0.05, 1.2, defaults.sounds.bgm.release),
                stereoSpread: clampSoundValue(rawSounds.bgm?.stereoSpread, 0, 1, defaults.sounds.bgm.stereoSpread),
                humanize: clampSoundValue(rawSounds.bgm?.humanize, 0, 0.12, defaults.sounds.bgm.humanize),
                detune: clampSoundValue(rawSounds.bgm?.detune, 0, 36, defaults.sounds.bgm.detune)
            }
        }
    };
}

function cloneSoundConfig(config = SOUND_EDITOR_DEFAULT_CONFIG) {
    return sanitizeSoundConfig(JSON.parse(JSON.stringify(config)));
}

class SoundEngine {
    constructor() {
        this.ctx = null;
        this.enabled = true;
        this.outputGainBoost = 3.8;
        this.volume = this.readStoredVolume();
        this.config = this.readStoredSoundConfig();
        this.gameplayMuted = false;
        this.previewPaused = false;
        this.currentPreviewKey = null;
        this.movementState = { active: false, speed: 1, nextStepTime: 0, stepIndex: 0 };
        this.loopPreviewState = null;
        this.bgmState = { nextNoteTime: 0, stepIndex: 0 };
        this.bgmPreviewState = null;
    }

    readStoredVolume() {
        try {
            const raw = window.localStorage.getItem('jkp-master-volume');
            if (raw === null) return 0.9;
            const parsed = Number(raw);
            return Number.isFinite(parsed) ? THREE.MathUtils.clamp(parsed, 0, 1) : 0.9;
        } catch {
            return 0.9;
        }
    }

    setVolume(value) {
        this.volume = THREE.MathUtils.clamp(value, 0, 1);
        try {
            window.localStorage.setItem('jkp-master-volume', String(this.volume));
        } catch {}
    }

    getContext() {
        if (this.ctx) return this.ctx;
        const Ctx = window.AudioContext || window.webkitAudioContext;
        if (!Ctx) return null;
        this.ctx = new Ctx();
        return this.ctx;
    }

    readStoredSoundConfig() {
        try {
            const raw = window.localStorage.getItem(SOUND_EDITOR_STORAGE_KEY);
            if (!raw) return cloneSoundConfig();
            return sanitizeSoundConfig(JSON.parse(raw));
        } catch {
            return cloneSoundConfig();
        }
    }

    cloneSoundConfig(config = this.config) {
        return cloneSoundConfig(config);
    }

    saveSoundConfig(config) {
        this.config = sanitizeSoundConfig(config);
        try {
            window.localStorage.setItem(SOUND_EDITOR_STORAGE_KEY, JSON.stringify(this.config));
        } catch {}
        if (!this.config.sounds.bgm.enabled) this.bgmState.nextNoteTime = 0;
        else this.seedBgmState();
    }

    async unlock() {
        const ctx = this.getContext();
        if (!ctx) return;
        if (ctx.state === 'suspended') {
            try { await ctx.resume(); } catch {}
        }
        if (this.bgmState.nextNoteTime <= 0) {
            this.bgmState.nextNoteTime = ctx.currentTime + 0.04;
            this.bgmState.stepIndex = 0;
        }
        if (this.movementState.active && this.movementState.nextStepTime <= 0) {
            this.movementState.nextStepTime = ctx.currentTime + 0.02;
        }
        if (this.loopPreviewState && this.loopPreviewState.nextStepTime <= 0) {
            this.loopPreviewState.nextStepTime = ctx.currentTime + 0.03;
        }
        if (this.bgmPreviewState && this.bgmPreviewState.nextNoteTime <= 0) {
            this.bgmPreviewState.nextNoteTime = ctx.currentTime + 0.03;
        }
    }

    setGameplayMuted(muted) {
        this.gameplayMuted = !!muted;
        if (this.gameplayMuted) {
            this.movementState.nextStepTime = 0;
            this.bgmState.nextNoteTime = 0;
            return;
        }
        this.seedMovementState();
        this.seedBgmState();
    }

    seedMovementState() {
        const ctx = this.getContext();
        if (!ctx || ctx.state !== 'running' || !this.movementState.active) return;
        this.movementState.nextStepTime = ctx.currentTime + 0.02;
    }

    seedBgmState() {
        const ctx = this.getContext();
        if (!ctx || ctx.state !== 'running' || !this.config.sounds.bgm.enabled) return;
        this.bgmState.nextNoteTime = ctx.currentTime + 0.04;
    }

    pausePreview() {
        this.previewPaused = true;
    }

    resumePreview() {
        const ctx = this.getContext();
        if (!ctx || ctx.state !== 'running') return;
        this.previewPaused = false;
        if (this.loopPreviewState) this.loopPreviewState.nextStepTime = ctx.currentTime + 0.03;
        if (this.bgmPreviewState) this.bgmPreviewState.nextNoteTime = ctx.currentTime + 0.03;
    }

    isContinuousPreviewActive(key = null) {
        if (!key) return !!(this.loopPreviewState || this.bgmPreviewState);
        if (key === 'footsteps') return !!this.loopPreviewState;
        if (key === 'bgm') return !!this.bgmPreviewState;
        return false;
    }

    updatePreviewConfig(key, configOverride) {
        const config = sanitizeSoundConfig(configOverride || this.config);
        const ctx = this.getContext();
        if (key === 'footsteps' && this.loopPreviewState) {
            this.loopPreviewState.config = config;
            if (ctx && ctx.state === 'running') this.loopPreviewState.nextStepTime = Math.min(this.loopPreviewState.nextStepTime || Infinity, ctx.currentTime + 0.02);
            return;
        }
        if (key === 'bgm' && this.bgmPreviewState) {
            this.bgmPreviewState.config = config;
            if (ctx && ctx.state === 'running') this.bgmPreviewState.nextNoteTime = Math.min(this.bgmPreviewState.nextNoteTime || Infinity, ctx.currentTime + 0.02);
        }
    }

    getEffectiveVolume() {
        return THREE.MathUtils.clamp(Math.pow(this.volume, 0.72) * this.outputGainBoost, 0, 4.8);
    }

    midiToFreq(note) {
        return 440 * Math.pow(2, (note - 69) / 12);
    }

    createDistortionCurve(amount = 0) {
        const k = Math.max(0, amount) * 220;
        const nSamples = 44100;
        const curve = new Float32Array(nSamples);
        const deg = Math.PI / 180;
        for (let i = 0; i < nSamples; i++) {
            const x = i * 2 / nSamples - 1;
            curve[i] = ((3 + k) * x * 20 * deg) / (Math.PI + k * Math.abs(x));
        }
        return curve;
    }

    createPanner(pan = 0) {
        const ctx = this.getContext();
        if (!ctx) return null;
        if (ctx.createStereoPanner) {
            const panner = ctx.createStereoPanner();
            panner.pan.value = THREE.MathUtils.clamp(pan, -1, 1);
            return panner;
        }
        return null;
    }

    scheduleVoice(config, {
        startTime = null,
        volumeMul = 1,
        freqMul = 1,
        durationMul = 1,
        panOffset = 0,
        brightnessMul = 1
    } = {}) {
        if (!this.enabled || this.volume <= 0.001) return;
        const ctx = this.getContext();
        if (!ctx || ctx.state !== 'running') return;

        const now = startTime ?? ctx.currentTime;
        const duration = Math.max(0.02, config.duration * durationMul);
        const attack = Math.max(0.001, config.attack);
        const hold = Math.max(0, config.hold);
        const release = Math.max(0.01, config.release);
        const totalDuration = Math.max(duration, attack + hold + release);
        const effectiveVolume = this.getEffectiveVolume();
        const baseGain = THREE.MathUtils.clamp(config.volume * volumeMul * effectiveVolume, 0, 1.8);

        const osc = ctx.createOscillator();
        osc.type = config.waveform;
        osc.frequency.setValueAtTime(Math.max(40, config.startFreq * freqMul), now);
        osc.frequency.exponentialRampToValueAtTime(Math.max(40, config.endFreq * freqMul), now + Math.max(0.02, duration));

        const filter = ctx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.setValueAtTime(Math.max(100, config.filterCutoff * brightnessMul), now);
        filter.Q.setValueAtTime(config.resonance, now);

        const gain = ctx.createGain();
        gain.gain.setValueAtTime(0.0001, now);
        gain.gain.linearRampToValueAtTime(Math.max(0.0001, baseGain), now + attack);
        gain.gain.setValueAtTime(Math.max(0.0001, baseGain), now + Math.max(attack, duration - release));
        gain.gain.exponentialRampToValueAtTime(0.0001, now + totalDuration);

        const voiceBus = ctx.createGain();
        voiceBus.gain.value = 1;
        const dryGain = ctx.createGain();
        dryGain.gain.value = Math.max(0, 1 - config.delayMix * 0.65);
        const wetGain = ctx.createGain();
        wetGain.gain.value = config.delayMix * 0.55;
        const destinationPanner = this.createPanner((config.pan || 0) + panOffset);

        let outNode = filter;
        if (config.distortion > 0.001) {
            const shaper = ctx.createWaveShaper();
            shaper.curve = this.createDistortionCurve(config.distortion);
            shaper.oversample = '4x';
            filter.connect(shaper);
            outNode = shaper;
        }

        outNode.connect(gain);
        gain.connect(dryGain);
        gain.connect(voiceBus);

        const delay = ctx.createDelay();
        delay.delayTime.setValueAtTime(Math.min(0.32, totalDuration * 0.65), now);
        const feedback = ctx.createGain();
        feedback.gain.setValueAtTime(0.18 + config.delayMix * 0.24, now);
        voiceBus.connect(delay);
        delay.connect(feedback);
        feedback.connect(delay);
        delay.connect(wetGain);

        const finalBus = ctx.createGain();
        dryGain.connect(finalBus);
        wetGain.connect(finalBus);

        if (destinationPanner) {
            finalBus.connect(destinationPanner);
            destinationPanner.connect(ctx.destination);
        } else {
            finalBus.connect(ctx.destination);
        }

        let subOsc = null;
        if (config.subMix > 0.001) {
            subOsc = ctx.createOscillator();
            subOsc.type = config.waveform === 'square' ? 'triangle' : 'sine';
            subOsc.frequency.setValueAtTime(Math.max(30, config.startFreq * 0.5 * freqMul), now);
            subOsc.frequency.exponentialRampToValueAtTime(Math.max(30, config.endFreq * 0.5 * freqMul), now + Math.max(0.02, duration));
            const subGain = ctx.createGain();
            subGain.gain.setValueAtTime(Math.max(0.0001, baseGain * config.subMix), now);
            subGain.gain.exponentialRampToValueAtTime(0.0001, now + totalDuration);
            subOsc.connect(subGain);
            subGain.connect(voiceBus);
        }

        let vibratoOsc = null;
        let vibratoGain = null;
        if (config.vibratoDepth > 0.001 && config.vibratoRate > 0.001) {
            vibratoOsc = ctx.createOscillator();
            vibratoGain = ctx.createGain();
            vibratoOsc.type = 'sine';
            vibratoOsc.frequency.setValueAtTime(config.vibratoRate, now);
            vibratoGain.gain.setValueAtTime(config.vibratoDepth, now);
            vibratoOsc.connect(vibratoGain);
            vibratoGain.connect(osc.frequency);
            if (subOsc) vibratoGain.connect(subOsc.frequency);
            vibratoOsc.start(now);
            vibratoOsc.stop(now + totalDuration + 0.05);
        }

        if (config.detune > 0.001) osc.detune.setValueAtTime(config.detune, now);

        osc.connect(filter);
        osc.start(now);
        osc.stop(now + totalDuration + 0.05);
        if (subOsc) {
            subOsc.start(now);
            subOsc.stop(now + totalDuration + 0.05);
        }
    }

    beep({
        freq = 440,
        duration = 0.12,
        volume = 0.03,
        type = 'triangle',
        slideTo = null,
        delay = 0,
        q = 3
    } = {}) {
        this.scheduleVoice(createOneShotSoundConfig({
            waveform: type,
            volume,
            startFreq: freq,
            endFreq: slideTo || freq,
            duration,
            filterCutoff: 2800,
            resonance: q
        }), { startTime: (this.getContext()?.currentTime || 0) + delay });
    }

    playOneShot(key, overrides = {}, configSet = this.config, options = {}) {
        if (this.gameplayMuted && !options.ignoreGameplayMute) return;
        const sound = configSet?.sounds?.[key];
        if (!sound) return;
        const ctx = this.getContext();
        if (!ctx || ctx.state !== 'running') return;
        const baseTime = ctx.currentTime + (overrides.delay || 0);
        this.scheduleVoice(sound, {
            startTime: baseTime,
            volumeMul: overrides.volumeMul || 1,
            freqMul: overrides.freqMul || 1,
            durationMul: overrides.durationMul || 1,
            panOffset: overrides.panOffset || 0
        });

        if (key === 'upgrade' || key === 'chest' || key === 'levelClear') {
            this.scheduleVoice({ ...sound, waveform: 'sine', startFreq: sound.endFreq, endFreq: sound.endFreq * 1.35, volume: sound.volume * 0.62, duration: sound.duration * 1.08, subMix: 0, delayMix: sound.delayMix * 1.2 }, { startTime: baseTime + 0.045, panOffset: 0.16 });
        }
        if (key === 'enemyDefeat' || key === 'defeat') {
            this.scheduleVoice({ ...sound, waveform: 'triangle', startFreq: sound.startFreq * 0.52, endFreq: sound.endFreq * 0.68, volume: sound.volume * 0.54, duration: sound.duration * 1.15, delayMix: sound.delayMix * 0.5 }, { startTime: baseTime + 0.06, panOffset: -0.12 });
        }
        if (key === 'bossIntro') {
            this.scheduleVoice({ ...sound, waveform: 'square', startFreq: sound.startFreq * 2, endFreq: sound.endFreq * 1.9, volume: sound.volume * 0.35, duration: sound.duration * 0.65, filterCutoff: sound.filterCutoff * 1.8, subMix: 0 }, { startTime: baseTime + 0.08, panOffset: 0.2 });
        }
    }

    setMovementState(active, speed = 1) {
        const nextActive = !!active;
        if (!nextActive) {
            this.movementState.active = false;
            this.movementState.nextStepTime = 0;
            return;
        }
        this.movementState.speed = THREE.MathUtils.clamp(speed, 0.55, 2.4);
        if (!this.movementState.active) {
            this.movementState.active = true;
            this.movementState.stepIndex = 0;
            const ctx = this.getContext();
            this.movementState.nextStepTime = ctx && ctx.state === 'running' ? ctx.currentTime + 0.02 : 0;
        }
    }

    scheduleFootstepState(state, config) {
        const ctx = this.getContext();
        if (!ctx || ctx.state !== 'running' || !config) return;
        if (state.until && ctx.currentTime >= state.until) {
            if (state === this.loopPreviewState) this.loopPreviewState = null;
            return;
        }
        if (state.nextStepTime <= 0 || state.nextStepTime < ctx.currentTime - 0.4) state.nextStepTime = ctx.currentTime + 0.02;

        const speedFactor = THREE.MathUtils.clamp(state.speed || 1, 0.55, 2.4);
        const baseInterval = (60 / config.tempo) * config.stepBeats / (config.stride * speedFactor);
        const horizon = ctx.currentTime + 0.22;
        while (state.nextStepTime < horizon && (!state.until || state.nextStepTime < state.until)) {
            const accentMul = state.stepIndex % 2 === 0 ? config.accent : 1;
            for (const track of config.tracks.slice(0, SOUND_EDITOR_MAX_TRACKS)) {
                if (!track.enabled) continue;
                if ((state.stepIndex % track.stepDiv) !== (track.offset % track.stepDiv)) continue;
                this.scheduleVoice(track, {
                    startTime: state.nextStepTime,
                    volumeMul: config.volume * accentMul,
                    freqMul: 1 + (speedFactor - 1) * 0.06
                });
            }
            state.stepIndex += 1;
            const swing = state.stepIndex % 2 === 0 ? 0 : baseInterval * config.swing * 0.5;
            state.nextStepTime += baseInterval + swing;
        }
    }

    scheduleBgmState(state, config) {
        const ctx = this.getContext();
        if (!ctx || ctx.state !== 'running' || !config?.enabled) return;
        const kernel = BGM_KERNELS[config.kernel] || BGM_KERNELS.warmPop;
        if (state.nextNoteTime <= 0 || state.nextNoteTime < ctx.currentTime - 1) state.nextNoteTime = ctx.currentTime + 0.03;
        const horizon = ctx.currentTime + 0.35;
        const stepDuration = 60 / config.tempo / 2;

        while (state.nextNoteTime < horizon && (!state.until || state.nextNoteTime < state.until)) {
            const chordIndex = Math.floor(state.stepIndex / 8) % kernel.progression.length;
            const chord = kernel.progression[chordIndex];
            const melodyDegree = kernel.melody[state.stepIndex % kernel.melody.length];
            const chordDegree = chord[state.stepIndex % chord.length];
            const melodyNote = config.root + melodyDegree;
            const chordNote = config.root + chordDegree + (state.stepIndex % 4 === 0 ? 12 : 0);
            const humanize = (Math.random() * 2 - 1) * config.humanize;
            const start = state.nextNoteTime + humanize;
            const duration = Math.max(0.08, stepDuration * config.noteLength);
            const brightnessCutoff = 800 + config.brightness * 4200;
            const pan = Math.sin(state.stepIndex * 0.8) * config.stereoSpread;

            this.scheduleVoice(createOneShotSoundConfig({
                waveform: 'triangle',
                volume: config.volume * 0.72,
                startFreq: this.midiToFreq(chordNote),
                endFreq: this.midiToFreq(chordNote),
                duration,
                attack: config.attack,
                hold: duration * 0.42,
                release: config.release,
                filterCutoff: brightnessCutoff,
                resonance: 1.8,
                detune: config.detune,
                subMix: 0.18,
                delayMix: 0.18,
                pan
            }), { startTime: start });

            this.scheduleVoice(createOneShotSoundConfig({
                waveform: state.stepIndex % 2 === 0 ? 'square' : 'sine',
                volume: config.volume * 0.46,
                startFreq: this.midiToFreq(melodyNote + 12),
                endFreq: this.midiToFreq(melodyNote + 12),
                duration: duration * 0.78,
                attack: Math.max(0.002, config.attack * 0.6),
                hold: duration * 0.18,
                release: config.release * 0.85,
                filterCutoff: brightnessCutoff * 1.15,
                resonance: 1.2,
                detune: config.detune * 0.4,
                subMix: 0,
                delayMix: 0.12,
                pan: -pan
            }), { startTime: start + 0.01 });

            state.stepIndex += 1;
            const swing = state.stepIndex % 2 === 0 ? 0 : stepDuration * config.swing * 0.45;
            state.nextNoteTime += stepDuration + swing;
        }

        if (state.until && ctx.currentTime >= state.until && state === this.bgmPreviewState) {
            this.bgmPreviewState = null;
        }
    }

    update() {
        const ctx = this.getContext();
        if (!ctx || ctx.state !== 'running') return;
        if (!this.gameplayMuted) {
            if (this.movementState.active) this.scheduleFootstepState(this.movementState, this.config.sounds.footsteps);
            this.scheduleBgmState(this.bgmState, this.config.sounds.bgm);
        }
        if (!this.previewPaused && this.loopPreviewState) this.scheduleFootstepState(this.loopPreviewState, this.loopPreviewState.config.sounds.footsteps);
        if (!this.previewPaused && this.bgmPreviewState) this.scheduleBgmState(this.bgmPreviewState, this.bgmPreviewState.config.sounds.bgm);
    }

    previewSound(key, configOverride) {
        const config = sanitizeSoundConfig(configOverride || this.config);
        this.stopPreview();
        this.previewPaused = false;
        this.currentPreviewKey = key;
        if (key === 'footsteps') {
            const ctx = this.getContext();
            if (!ctx || ctx.state !== 'running') return;
            this.loopPreviewState = {
                config,
                speed: 1.1,
                nextStepTime: ctx.currentTime + 0.03,
                stepIndex: 0
            };
            return;
        }
        if (key === 'bgm') {
            const ctx = this.getContext();
            if (!ctx || ctx.state !== 'running') return;
            this.bgmPreviewState = {
                config,
                nextNoteTime: ctx.currentTime + 0.03,
                stepIndex: 0
            };
            return;
        }
        this.playOneShot(key, {}, config, { ignoreGameplayMute: true });
    }

    stopPreview() {
        this.previewPaused = false;
        this.currentPreviewKey = null;
        this.loopPreviewState = null;
        this.bgmPreviewState = null;
    }

    upgrade() {
        this.playOneShot('upgrade');
    }

    chest() {
        this.playOneShot('chest');
    }

    levelClear() {
        this.playOneShot('levelClear');
    }

    enemyHit(isBoss = false) {
        this.playOneShot('enemyHit', {
            freqMul: isBoss ? 0.82 : 1,
            durationMul: isBoss ? 1.3 : 1,
            volumeMul: isBoss ? 1.35 : 1
        });
    }

    playerHit(isBoss = false) {
        this.playOneShot('playerHit', {
            freqMul: isBoss ? 0.78 : 1,
            durationMul: isBoss ? 1.24 : 1,
            volumeMul: isBoss ? 1.3 : 1
        });
    }

    enemyDefeat(isBoss = false) {
        this.playOneShot('enemyDefeat', {
            freqMul: isBoss ? 0.76 : 1,
            durationMul: isBoss ? 1.25 : 1,
            volumeMul: isBoss ? 1.35 : 1
        });
    }

    bossIntro() {
        this.playOneShot('bossIntro');
    }

    defeat() {
        this.playOneShot('defeat');
    }
}

// --- 闁绘鍩栭埀顑挎缁楀矂寮界粙璺ㄥ闂侇偅妲掔欢?---
const GameState = {
    phase: 'INIT',
    level: 1,
    score: 0,
    currentFloor: { key: 'combat', label: 'Combat Floor', note: 'Balanced pacing with steady risk and reward.' },
    player: { lvSpeed: 1, baseSpeed: 0.15, lvAtk: 1, baseAtk: 10, lvHp: 1, baseHp: 50, currentHp: 50 },
    maze: { lvChest: 1, baseChestRate: 0.05, lvMonster: 1, baseMonsterRate: 0.03, lvSize: 1, lvHidden: 1, baseSide: 11, maxSide: 25 },
    costs: {
        speed: () => Math.floor(10 * Math.pow(1.5, GameState.player.lvSpeed - 1)),
        atk: () => Math.floor(20 * Math.pow(1.5, GameState.player.lvAtk - 1)),
        hp: () => Math.floor(20 * Math.pow(1.4, GameState.player.lvHp - 1)),
        chest: () => Math.floor(50 * Math.pow(1.6, GameState.maze.lvChest - 1)),
        size: () => Math.floor(40 * Math.pow(1.7, GameState.maze.lvSize - 1)),
        hidden: () => Math.floor(80 * Math.pow(1.75, GameState.maze.lvHidden - 1)),
        monster: () => Math.floor(100 * Math.pow(1.8, GameState.maze.lvMonster - 1))
    },
    getMazeSide() {
        return Math.min(this.maze.maxSide, this.maze.baseSide + (this.maze.lvSize - 1) * 2);
    },
    getMazeDimensions() {
        const side = this.getMazeSide();
        return { cols: side, rows: side };
    },
    getMaxMazeSizeLevel() {
        return 1 + Math.floor((this.maze.maxSide - this.maze.baseSide) / 2);
    },
    isMazeSizeMaxed() {
        return this.maze.lvSize >= this.getMaxMazeSizeLevel();
    },
    getMazeSizeFactor() {
        const side = this.getMazeSide();
        return (side * side) / (this.maze.baseSide * this.maze.baseSide);
    },
    getHiddenRoomSpawnBonus() {
        return (this.maze.lvHidden - 1) * 0.035;
    },
    getHiddenRoomDiversionBonus() {
        return (this.maze.lvHidden - 1) * 0.055;
    },
    isBossUnlocked() {
        return this.maze.lvMonster >= 4;
    },
    getBossFloorChance() {
        if (!this.isBossUnlocked()) return 0;
        return Math.min(0.58, 0.14 + (this.maze.lvMonster - 4) * 0.11);
    },
    addScore(val) {
        this.score += val;
        const el = document.getElementById('ui-score');
        el.innerText = Math.floor(this.score);
        el.style.transform = 'scale(1.2)';
        el.style.color = '#ffffff';
        setTimeout(() => {
            el.style.transform = 'scale(1)';
            el.style.color = '#facc15';
        }, 150);
        this.updateUI();
    },
    spendScore(val) {
        const amount = Math.max(0, Math.floor(val));
        if (this.score < amount) return false;
        this.score -= amount;
        this.updateUI();
        return true;
    },
    tryBuy(type) {
        if (type === 'size' && this.isMazeSizeMaxed()) return false;
        const cost = this.costs[type]();
        if (this.score < cost) return false;

        this.spendScore(cost);
        if (type === 'speed') { this.player.lvSpeed++; this.player.baseSpeed = Math.max(0.04, this.player.baseSpeed - 0.015); }
        if (type === 'atk') { this.player.lvAtk++; this.player.baseAtk += 5; }
        if (type === 'hp') { this.player.lvHp++; this.player.baseHp += 20; this.player.currentHp = this.player.baseHp; }
        if (type === 'chest') { this.maze.lvChest++; this.maze.baseChestRate += 0.02; }
        if (type === 'size') { this.maze.lvSize++; }
        if (type === 'hidden') { this.maze.lvHidden++; }
        if (type === 'monster') { this.maze.lvMonster++; this.maze.baseMonsterRate += 0.015; }

        this.updateUI();
        window.soundEngine?.upgrade();
        if (window.engine) window.engine.triggerUpgradeEffect();
        return true;
    },
    updateUI() {
        document.getElementById('ui-level').innerText = this.level;
        document.getElementById('ui-floor-type').innerText = this.currentFloor.label;
        document.getElementById('rpg-p-lv').innerText = this.player.lvAtk + this.player.lvHp + this.player.lvSpeed;

        const statusSpan = document.getElementById('ui-status');
        const statusBox = document.getElementById('ui-status-box');
