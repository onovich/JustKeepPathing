    }

    resize() {
        const w = Math.max(300, this.container.clientWidth);
        const h = Math.max(300, this.container.clientHeight);
        this.camera.aspect = w / h;
        this.camera.updateProjectionMatrix();
        this.renderer.setSize(w, h);
        this.composer.setSize(w, h);
        this.playerOcclusionTarget.setSize(w, h);
    }

    readStoredAppearanceConfig() {
        try {
            const raw = window.localStorage.getItem(MODEL_EDITOR_STORAGE_KEY);
            if (!raw) return cloneAppearanceConfig();
            return sanitizeAppearanceConfig(JSON.parse(raw));
        } catch {
            return cloneAppearanceConfig();
        }
    }

    cloneAppearanceConfig(config = this.appearanceConfig) {
        return cloneAppearanceConfig(config);
    }

    saveAppearanceConfig(config) {
        this.appearanceConfig = sanitizeAppearanceConfig(config);
        try {
            window.localStorage.setItem(MODEL_EDITOR_STORAGE_KEY, JSON.stringify(this.appearanceConfig));
        } catch {}
    }

    fillColorAttribute(attribute, colorHex) {
        const color = new THREE.Color(colorHex);
        for (let i = 0; i < attribute.count; i++) {
            attribute.setXYZ(i, color.r, color.g, color.b);
        }
        attribute.needsUpdate = true;
    }

    fillScalarAttribute(attribute, value) {
        for (let i = 0; i < attribute.count; i++) attribute.setX(i, value);
        attribute.needsUpdate = true;
    }

    fillVector2Attribute(attribute, valueX, valueY) {
        for (let i = 0; i < attribute.count; i++) attribute.setXY(i, valueX, valueY);
        attribute.needsUpdate = true;
    }

    ensureEditableMesh(mesh, defaultColor) {
        if (mesh.userData.editorMeta?.kind === 'mesh') return;

        const sourceGeometry = mesh.geometry.index ? mesh.geometry.toNonIndexed() : mesh.geometry.clone();
        const position = sourceGeometry.getAttribute('position');
        const colorAttr = new THREE.Float32BufferAttribute(new Float32Array(position.count * 3), 3);
        const patternColorAttr = new THREE.Float32BufferAttribute(new Float32Array(position.count * 3), 3);
        const patternMetaAttr = new THREE.Float32BufferAttribute(new Float32Array(position.count * 2), 2);
        this.fillColorAttribute(colorAttr, defaultColor);
        this.fillColorAttribute(patternColorAttr, MODEL_EDITOR_DEFAULT_FACE_PATTERN.patternColor);
        this.fillVector2Attribute(patternMetaAttr, MODEL_EDITOR_FACE_PATTERN_IDS.none, MODEL_EDITOR_DEFAULT_FACE_PATTERN.patternScale);
        sourceGeometry.setAttribute('color', colorAttr);
        sourceGeometry.setAttribute('patternColor', patternColorAttr);
        sourceGeometry.setAttribute('patternMeta', patternMetaAttr);

        const material = mesh.material.clone();
        material.vertexColors = true;
        material.color.set(0xffffff);
        material.onBeforeCompile = (shader) => {
            shader.vertexShader = shader.vertexShader
                .replace(
                    '#include <common>',
                    '#include <common>\nattribute vec3 patternColor;\nattribute vec2 patternMeta;\nvarying vec3 vPatternColor;\nvarying vec2 vPatternMeta;\nvarying vec2 vEditorUv;'
                )
                .replace(
                    '#include <uv_vertex>',
                    '#include <uv_vertex>\nvEditorUv = uv;\nvPatternColor = patternColor;\nvPatternMeta = patternMeta;'
                );

            shader.fragmentShader = shader.fragmentShader
                .replace(
                    '#include <common>',
                    '#include <common>\nvarying vec3 vPatternColor;\nvarying vec2 vPatternMeta;\nvarying vec2 vEditorUv;\nfloat patternHalftone(vec2 uv) { vec2 gv = fract(uv) - 0.5; float d = length(gv); return 1.0 - smoothstep(0.16, 0.24, d); }\nfloat patternDither(vec2 uv) { vec2 gv = floor(uv * 2.0); return mod(gv.x + gv.y, 2.0) < 0.5 ? 0.0 : 0.72; }\nfloat patternHatch(vec2 uv) { float a = fract((uv.x + uv.y) * 0.7); return step(0.62, a) * 0.78; }\nfloat resolvePatternAlpha(float patternId, vec2 uv) { if (patternId < 0.5) return 0.0; if (patternId < 1.5) return patternHalftone(uv); if (patternId < 2.5) return patternDither(uv); return patternHatch(uv); }'
                )
                .replace(
                    'vec4 diffuseColor = vec4( diffuse, opacity );',
                    'vec4 diffuseColor = vec4( diffuse, opacity );\nfloat patternScale = max(vPatternMeta.y, 0.0001);\nfloat patternAlpha = resolvePatternAlpha(vPatternMeta.x, vEditorUv * patternScale);\ndiffuseColor.rgb = mix(diffuseColor.rgb, vPatternColor, patternAlpha);'
                );
        };
        mesh.geometry = sourceGeometry;
        mesh.material = material;
    }

    ensureEditableLineSegments(lines, defaultColor) {
        if (!lines || lines.userData.editorMeta?.kind === 'line') return;

        const sourceGeometry = lines.geometry.clone();
        const position = sourceGeometry.getAttribute('position');
        const colorAttr = new THREE.Float32BufferAttribute(new Float32Array(position.count * 3), 3);
        const alphaAttr = new THREE.Float32BufferAttribute(new Float32Array(position.count), 1);
        this.fillColorAttribute(colorAttr, defaultColor);
        this.fillScalarAttribute(alphaAttr, 1);
        sourceGeometry.setAttribute('color', colorAttr);
        sourceGeometry.setAttribute('lineAlpha', alphaAttr);

        const material = lines.material.clone();
        material.vertexColors = true;
        material.color.set(0xffffff);
        material.transparent = true;
        material.onBeforeCompile = (shader) => {
            shader.vertexShader = shader.vertexShader
                .replace(
                    '#include <common>',
                    '#include <common>\nattribute float lineAlpha;\nvarying float vLineAlpha;'
                )
                .replace(
                    '#include <begin_vertex>',
                    '#include <begin_vertex>\nvLineAlpha = lineAlpha;'
                );
            shader.fragmentShader = shader.fragmentShader
                .replace(
                    '#include <common>',
                    '#include <common>\nvarying float vLineAlpha;'
                )
                .replace(
                    'vec4 diffuseColor = vec4( diffuse, opacity );',
                    'vec4 diffuseColor = vec4( diffuse, opacity * vLineAlpha );'
                );
        };
        lines.geometry = sourceGeometry;
        lines.material = material;
    }

    setMeshFaceAppearance(mesh, faceIndex, appearance) {
        const colors = mesh.geometry.getAttribute('color');
        const patternColors = mesh.geometry.getAttribute('patternColor');
        const patternMeta = mesh.geometry.getAttribute('patternMeta');
        if (!colors || !patternColors || !patternMeta) return;
        const startVertex = faceIndex * 3;
        if (startVertex + 2 >= colors.count) return;
        const color = new THREE.Color(appearance.color);
        const patternColor = new THREE.Color(appearance.patternColor);
        const patternId = MODEL_EDITOR_FACE_PATTERN_IDS[appearance.pattern] ?? 0;
        for (let offset = 0; offset < 3; offset++) {
            colors.setXYZ(startVertex + offset, color.r, color.g, color.b);
            patternColors.setXYZ(startVertex + offset, patternColor.r, patternColor.g, patternColor.b);
            patternMeta.setXY(startVertex + offset, patternId, appearance.patternScale);
        }
        colors.needsUpdate = true;
        patternColors.needsUpdate = true;
        patternMeta.needsUpdate = true;
    }

    setLineSegmentColor(lines, segmentIndex, colorHex) {
        const colors = lines.geometry.getAttribute('color');
        if (!colors) return;
        const startVertex = segmentIndex * 2;
        if (startVertex + 1 >= colors.count) return;
        const color = new THREE.Color(colorHex);
        colors.setXYZ(startVertex, color.r, color.g, color.b);
        colors.setXYZ(startVertex + 1, color.r, color.g, color.b);
        colors.needsUpdate = true;
    }

    setLineSegmentAlpha(lines, segmentIndex, alphaValue) {
        const alpha = lines.geometry.getAttribute('lineAlpha');
        if (!alpha) return;
        const startVertex = segmentIndex * 2;
        if (startVertex + 1 >= alpha.count) return;
        alpha.setX(startVertex, alphaValue);
        alpha.setX(startVertex + 1, alphaValue);
        alpha.needsUpdate = true;
    }

    readMeshFaceAppearance(mesh, faceIndex) {
        const colors = mesh.geometry.getAttribute('color');
        const patternColors = mesh.geometry.getAttribute('patternColor');
        const patternMeta = mesh.geometry.getAttribute('patternMeta');
        const startVertex = faceIndex * 3;
        const fallback = mesh.userData.editorMeta?.defaultAppearance || {
            color: mesh.userData.editorMeta?.defaultColor || '#ffffff',
            pattern: MODEL_EDITOR_DEFAULT_FACE_PATTERN.pattern,
            patternColor: MODEL_EDITOR_DEFAULT_FACE_PATTERN.patternColor,
            patternScale: MODEL_EDITOR_DEFAULT_FACE_PATTERN.patternScale
        };
        if (!colors || !patternColors || !patternMeta || startVertex >= colors.count) return { ...fallback };
        const color = new THREE.Color().setRGB(colors.getX(startVertex), colors.getY(startVertex), colors.getZ(startVertex));
        const patternColor = new THREE.Color().setRGB(patternColors.getX(startVertex), patternColors.getY(startVertex), patternColors.getZ(startVertex));
        const patternId = Math.round(patternMeta.getX(startVertex));
        return {
            color: normalizeColorHex(color, fallback.color),
            pattern: MODEL_EDITOR_FACE_PATTERN_KEYS[patternId] || fallback.pattern,
            patternColor: normalizeColorHex(patternColor, fallback.patternColor),
            patternScale: Number(patternMeta.getY(startVertex).toFixed(2))
        };
    }

    readLineSegmentAppearance(lines, segmentIndex) {
        const colors = lines.geometry.getAttribute('color');
        const startVertex = segmentIndex * 2;
        const fallback = lines.userData.editorMeta?.defaultAppearance || {
            color: lines.userData.editorMeta?.defaultColor || '#ffffff',
            style: MODEL_EDITOR_DEFAULT_LINE_STYLE.style,
            width: MODEL_EDITOR_DEFAULT_LINE_STYLE.width
        };
        const color = colors && startVertex < colors.count
            ? new THREE.Color().setRGB(colors.getX(startVertex), colors.getY(startVertex), colors.getZ(startVertex))
            : null;
        return {
            color: normalizeColorHex(color, fallback.color),
            style: fallback.style,
            width: fallback.width
        };
    }

    clearLineOverrides(lines) {
        const group = lines.userData.overrideGroup;
        if (!group) return;
        while (group.children.length > 0) {
            const child = group.children[0];
            group.remove(child);
            child.geometry?.dispose?.();
            child.material?.dispose?.();
        }
    }

    createLineOverride(lines, segmentIndex, appearance) {
        const positions = lines.geometry.getAttribute('position');
        const startVertex = segmentIndex * 2;
        if (!positions || startVertex + 1 >= positions.count) return;
        const p1 = new THREE.Vector3().fromBufferAttribute(positions, startVertex);
        const p2 = new THREE.Vector3().fromBufferAttribute(positions, startVertex + 1);
        const geometry = new THREE.BufferGeometry().setFromPoints([p1, p2]);
        const material = appearance.style === 'dashed'
            ? new THREE.LineDashedMaterial({
                color: appearance.color,
                linewidth: appearance.width,
                dashSize: 0.06 * appearance.width,
                gapSize: 0.045 * appearance.width,
                transparent: true,
                opacity: 1
            })
            : new THREE.LineBasicMaterial({
                color: appearance.color,
                linewidth: appearance.width,
                transparent: true,
                opacity: 1
            });
        const line = new THREE.Line(geometry, material);
        if (appearance.style === 'dashed') line.computeLineDistances();
        lines.userData.overrideGroup?.add(line);
    }

    applyAppearanceConfigToEditable(target, config = this.appearanceConfig) {
        const meta = target?.userData?.editorMeta;
        if (!meta) return;

        const partConfig = getAppearancePart(config, meta.assetKey, meta.partKey, false);
        const overrides = partConfig ? (meta.kind === 'mesh' ? partConfig.faces : partConfig.lines) : {};
        const colors = target.geometry?.getAttribute('color');
        if (!colors) return;

        if (meta.kind === 'mesh') {
            const faceCount = Math.floor(colors.count / 3);
            for (let faceIndex = 0; faceIndex < faceCount; faceIndex++) {
                const faceAppearance = getFaceAppearanceEntry(partConfig, faceIndex, meta.defaultColor);
                this.setMeshFaceAppearance(target, faceIndex, faceAppearance);
            }
            return;
        }

        this.fillColorAttribute(colors, meta.defaultColor);
        this.fillScalarAttribute(target.geometry.getAttribute('lineAlpha'), 1);
        this.clearLineOverrides(target);

        const segmentCount = Math.floor(colors.count / 2);
        for (let segmentIndex = 0; segmentIndex < segmentCount; segmentIndex++) {
            const lineAppearance = getLineAppearanceEntry(partConfig, segmentIndex, meta.defaultColor);
            this.setLineSegmentColor(target, segmentIndex, lineAppearance.color);
            const needsOverlay = lineAppearance.style !== MODEL_EDITOR_DEFAULT_LINE_STYLE.style
                || Math.abs(lineAppearance.width - MODEL_EDITOR_DEFAULT_LINE_STYLE.width) > 0.001;
            if (needsOverlay) {
                this.setLineSegmentAlpha(target, segmentIndex, 0);
                this.createLineOverride(target, segmentIndex, lineAppearance);
            }
        }
    }

    applyAppearanceConfigToObject(root, config = this.appearanceConfig) {
        root?.traverse((child) => {
            if (child.userData?.editorMeta) this.applyAppearanceConfigToEditable(child, config);
        });
    }

    applyAppearanceConfigToLiveScene() {
        this.applyAppearanceConfigToObject(this.playerObj);
        for (const entity of this.entities) this.applyAppearanceConfigToObject(entity.mesh);
    }

    tagEditableAssembly(group, assetKey, partKey, meshColor, lineColor) {
        const mesh = group.userData.mesh;
        const lines = group.children.find((child) => child.isLineSegments) || null;
        const meshHex = normalizeColorHex(meshColor, '#ffffff');
        const lineHex = normalizeColorHex(lineColor, '#0f172a');

        this.ensureEditableMesh(mesh, meshHex);
        mesh.userData.editorMeta = {
            kind: 'mesh',
            assetKey,
            partKey,
            defaultColor: meshHex,
            defaultAppearance: {
                color: meshHex,
                pattern: MODEL_EDITOR_DEFAULT_FACE_PATTERN.pattern,
                patternColor: MODEL_EDITOR_DEFAULT_FACE_PATTERN.patternColor,
                patternScale: MODEL_EDITOR_DEFAULT_FACE_PATTERN.patternScale
            }
        };

        if (lines) {
            this.ensureEditableLineSegments(lines, lineHex);
            const overrideGroup = new THREE.Group();
            overrideGroup.userData.editorOverlay = true;
            group.add(overrideGroup);
            lines.userData.overrideGroup = overrideGroup;
            lines.userData.editorMeta = {
                kind: 'line',
                assetKey,
                partKey,
                defaultColor: lineHex,
                defaultAppearance: {
                    color: lineHex,
                    style: MODEL_EDITOR_DEFAULT_LINE_STYLE.style,
                    width: MODEL_EDITOR_DEFAULT_LINE_STYLE.width
                }
            };
        }

        group.userData.mesh = mesh;
        group.userData.lines = lines;
        group.userData.assetKey = assetKey;
        group.userData.partKey = partKey;
        this.applyAppearanceConfigToEditable(mesh);
        if (lines) this.applyAppearanceConfigToEditable(lines);
        return group;
    }

    createOutlinedAssembly(geometry, material, edgeColor = 0x020617) {
        const group = new THREE.Group();
        const mesh = new THREE.Mesh(geometry, material);
        const edges = new THREE.LineSegments(
            new THREE.EdgesGeometry(geometry),
            new THREE.LineBasicMaterial({ color: edgeColor, linewidth: 2 })
        );
        group.add(mesh);
        group.add(edges);
        group.userData.mesh = mesh;
        return group;
    }

    sampleIndices(count, maxVisible) {
        if (count <= maxVisible) return Array.from({ length: count }, (_, index) => index);
        const result = [];
        for (let i = 0; i < maxVisible; i++) {
            const index = Math.floor(i * count / maxVisible);
            if (!result.includes(index)) result.push(index);
        }
        return result;
    }

    createLineLoop(points, color, opacity = 1) {
        const geometry = new THREE.BufferGeometry().setFromPoints(points);
        return new THREE.LineLoop(geometry, new THREE.LineBasicMaterial({ color, transparent: opacity < 1, opacity }));
    }

    createLinePath(points, color, opacity = 1) {
        const geometry = new THREE.BufferGeometry().setFromPoints(points);
        return new THREE.Line(geometry, new THREE.LineBasicMaterial({ color, transparent: opacity < 1, opacity }));
    }

    createSparseCylinderLines(radiusTop, radiusBottom, height, radialSegments, color) {
        if (radialSegments <= 14) {
            return new THREE.LineSegments(
                new THREE.EdgesGeometry(new THREE.CylinderGeometry(radiusTop, radiusBottom, height, radialSegments)),
                new THREE.LineBasicMaterial({ color })
            );
        }

        const group = new THREE.Group();
        const rimSamples = this.sampleIndices(radialSegments, 16);
        const verticalSamples = this.sampleIndices(radialSegments, 8);
        const halfHeight = height / 2;

        const makeCircle = (radius, y) => rimSamples.map((index) => {
            const angle = index / radialSegments * Math.PI * 2;
            return new THREE.Vector3(Math.cos(angle) * radius, y, Math.sin(angle) * radius);
        });

        group.add(this.createLineLoop(makeCircle(radiusTop, halfHeight), color));
        group.add(this.createLineLoop(makeCircle(radiusBottom, -halfHeight), color));

        if (Math.abs(radiusTop - radiusBottom) > 0.02) {
            const midRadius = (radiusTop + radiusBottom) * 0.5;
            group.add(this.createLineLoop(makeCircle(midRadius, 0), color, 0.85));
        }

        for (const index of verticalSamples) {
            const angle = index / radialSegments * Math.PI * 2;
            const top = new THREE.Vector3(Math.cos(angle) * radiusTop, halfHeight, Math.sin(angle) * radiusTop);
            const bottom = new THREE.Vector3(Math.cos(angle) * radiusBottom, -halfHeight, Math.sin(angle) * radiusBottom);
            group.add(this.createLinePath([top, bottom], color, 0.9));
        }

        return group;
    }

    createSparseSphereDomeLines(radius, widthSegments, heightSegments, color) {
        if (widthSegments <= 14) {
            return new THREE.LineSegments(
                new THREE.EdgesGeometry(new THREE.SphereGeometry(radius, widthSegments, heightSegments, 0, Math.PI * 2, 0, Math.PI / 2)),
                new THREE.LineBasicMaterial({ color })
            );
        }

        const group = new THREE.Group();
        const latitudes = this.sampleIndices(heightSegments, 5).filter((index) => index > 0);
        const longitudes = this.sampleIndices(widthSegments, 8);

        for (const latIndex of latitudes) {
            const theta = latIndex / heightSegments * (Math.PI / 2);
            const y = Math.cos(theta) * radius;
            const ringRadius = Math.sin(theta) * radius;
            const ringPoints = [];
            const segments = widthSegments <= 18 ? widthSegments : 18;
            for (let i = 0; i < segments; i++) {
                const phi = i / segments * Math.PI * 2;
                ringPoints.push(new THREE.Vector3(Math.cos(phi) * ringRadius, y, Math.sin(phi) * ringRadius));
            }
            group.add(this.createLineLoop(ringPoints, color, 0.9));
        }

        for (const lonIndex of longitudes) {
            const phi = lonIndex / widthSegments * Math.PI * 2;
            const points = [];
            const segments = heightSegments <= 10 ? heightSegments : 8;
            for (let i = 0; i <= segments; i++) {
                const theta = i / segments * (Math.PI / 2);
                points.push(new THREE.Vector3(
                    Math.cos(phi) * Math.sin(theta) * radius,
                    Math.cos(theta) * radius,
                    Math.sin(phi) * Math.sin(theta) * radius
                ));
            }
            group.add(this.createLinePath(points, color, 0.85));
        }

        return group;
    }

    createSparseTorusLines(radius, tube, radialSegments, tubularSegments, color) {
        if (Math.max(radialSegments, tubularSegments) <= 16) {
            return new THREE.LineSegments(
                new THREE.EdgesGeometry(new THREE.TorusGeometry(radius, tube, radialSegments, tubularSegments)),
                new THREE.LineBasicMaterial({ color })
            );
        }

        const group = new THREE.Group();
        const radialIndices = this.sampleIndices(radialSegments, radialSegments > 18 ? 6 : radialSegments);
        const tubularIndices = this.sampleIndices(tubularSegments, tubularSegments > 20 ? 10 : tubularSegments);

        for (const radialIndex of radialIndices) {
            const v = radialIndex / radialSegments * Math.PI * 2;
            const points = [];
            for (let i = 0; i < tubularSegments; i++) {
                const u = i / tubularSegments * Math.PI * 2;
                points.push(new THREE.Vector3(
                    (radius + tube * Math.cos(v)) * Math.cos(u),
                    tube * Math.sin(v),
                    (radius + tube * Math.cos(v)) * Math.sin(u)
                ));
            }
            group.add(this.createLineLoop(points, color, 0.82));
        }

        for (const tubularIndex of tubularIndices) {
            const u = tubularIndex / tubularSegments * Math.PI * 2;
            const points = [];
            for (let i = 0; i < radialSegments; i++) {
                const v = i / radialSegments * Math.PI * 2;
                points.push(new THREE.Vector3(
                    (radius + tube * Math.cos(v)) * Math.cos(u),
                    tube * Math.sin(v),
                    (radius + tube * Math.cos(v)) * Math.sin(u)
                ));
            }
            group.add(this.createLineLoop(points, color, 0.9));
        }

        return group;
    }

    createAssemblyWithCustomLines(geometry, material, lines) {
        const group = new THREE.Group();
        const mesh = new THREE.Mesh(geometry, material);
        group.add(mesh);
        group.add(lines);
        group.userData.mesh = mesh;
        return group;
    }

    enableOcclusionRevealLayer(root) {
        root.traverse((child) => {
            if (child.isMesh) child.layers.enable(1);
        });
        return root;
    }

    applyOccluderRevealShader(material, revealOpacity = 0.2) {
        material.transparent = true;
        material.onBeforeCompile = (shader) => {
            shader.uniforms.uPlayerMaskTexture = { value: this.playerOcclusionTarget.texture };
            shader.uniforms.uPlayerDepthTexture = { value: this.playerOcclusionTarget.depthTexture };
            shader.uniforms.uRevealResolution = {
                value: new THREE.Vector2(this.playerOcclusionTarget.width, this.playerOcclusionTarget.height)
            };
            shader.uniforms.uRevealOpacity = { value: revealOpacity };
            shader.uniforms.uDepthBias = { value: 0.002 };
            shader.uniforms.uRevealEnabled = { value: 0 };

            shader.fragmentShader = shader.fragmentShader.replace(
                '#include <common>',
                '#include <common>\nuniform sampler2D uPlayerMaskTexture;\nuniform sampler2D uPlayerDepthTexture;\nuniform vec2 uRevealResolution;\nuniform float uRevealOpacity;\nuniform float uDepthBias;\nuniform float uRevealEnabled;\nvoid jkpAccumulatePlayerSample(vec2 uv, inout float mask, inout float depth) {\n    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) return;\n    float sampleMask = texture2D(uPlayerMaskTexture, uv).r;\n    if (sampleMask <= 0.01) return;\n    mask = max(mask, sampleMask);\n    depth = max(depth, texture2D(uPlayerDepthTexture, uv).r);\n}\nfloat jkpOcclusionMask(vec2 uv, float wallDepth) {\n    vec2 texel = 1.0 / max(uRevealResolution, vec2(1.0));\n    float playerMask = 0.0;\n    float playerDepth = 0.0;\n    jkpAccumulatePlayerSample(uv, playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv + vec2(texel.x * 1.5, 0.0), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv - vec2(texel.x * 1.5, 0.0), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv + vec2(0.0, texel.y * 1.5), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv - vec2(0.0, texel.y * 1.5), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv + texel * vec2(1.1, 1.1), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv + texel * vec2(-1.1, 1.1), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv + texel * vec2(1.1, -1.1), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv + texel * vec2(-1.1, -1.1), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv + vec2(texel.x * 2.4, 0.0), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv - vec2(texel.x * 2.4, 0.0), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv + vec2(0.0, texel.y * 2.4), playerMask, playerDepth);\n    jkpAccumulatePlayerSample(uv - vec2(0.0, texel.y * 2.4), playerMask, playerDepth);\n    float hasPlayer = step(0.01, playerMask) * (1.0 - step(0.9999, playerDepth));\n    float wallInFront = step(wallDepth + uDepthBias, playerDepth);\n    return hasPlayer * wallInFront;\n}'
            ).replace(
                'vec4 diffuseColor = vec4( diffuse, opacity );',
                'vec4 diffuseColor = vec4( diffuse, opacity );\nvec2 revealUv = gl_FragCoord.xy / max(uRevealResolution, vec2(1.0));\nfloat wallDepth = gl_FragCoord.z;\nfloat revealStrength = jkpOcclusionMask(revealUv, wallDepth) * uRevealEnabled;\ndiffuseColor.a = mix(diffuseColor.a, uRevealOpacity, revealStrength);'
            );

            material.userData.shader = shader;
        };
        return material;
    }

    createWallMaterial() {
        return this.applyOccluderRevealShader(this.materials.wallBox.clone(), 0.2);
    }

    createWallEdgeMaterial() {
        return this.applyOccluderRevealShader(
            new THREE.LineBasicMaterial({ color: 0x000000, linewidth: 2, transparent: true, opacity: 1 }),
            0.12
        );
    }

    createWallCell(wallGeo, edgesGeo, pos) {
        const group = new THREE.Group();
        const boxMaterial = this.createWallMaterial();
        const boxMesh = new THREE.Mesh(wallGeo, boxMaterial);
        const edgeMaterial = this.createWallEdgeMaterial();
        const edgeMesh = new THREE.LineSegments(edgesGeo, edgeMaterial);
        group.add(boxMesh);
        group.add(edgeMesh);
        group.position.set(pos.x, 0.25, pos.z);

        const occluder = {
            group,
            boxMesh,
            edgeMesh,
            baseEdgeOpacity: 1
        };
        this.occluders.push(occluder);
        this.occluderLookup.set(boxMesh.uuid, occluder);
        return group;
    }

    hasVisibleOcclusionSubjects() {
        let hasVisibleSubject = false;
        this.scene.traverseVisible((child) => {
            if (hasVisibleSubject) return;
            if (!child.isMesh) return;
            if (!child.layers.test(this.camera.layers)) return;
            if (!child.layers.isEnabled(1)) return;
            hasVisibleSubject = true;
        });
        return hasVisibleSubject;
    }

    renderPlayerOcclusionMask() {
        if (!this.hasVisibleOcclusionSubjects()) return false;

        const previousRenderTarget = this.renderer.getRenderTarget();
        const previousAutoClear = this.renderer.autoClear;
        const previousOverrideMaterial = this.scene.overrideMaterial;
        const previousBackground = this.scene.background;
        const previousLayerMask = this.camera.layers.mask;
        const previousClearColor = this.renderer.getClearColor(new THREE.Color()).clone();
        const previousClearAlpha = this.renderer.getClearAlpha();

        this.renderer.setRenderTarget(this.playerOcclusionTarget);
        this.renderer.autoClear = true;
        this.renderer.setClearColor(0x000000, 0);
        this.scene.background = null;
        this.scene.overrideMaterial = this.playerMaskMaterial;
        this.camera.layers.set(1);
        this.renderer.clear(true, true, true);
        this.renderer.render(this.scene, this.camera);

        this.camera.layers.mask = previousLayerMask;
        this.scene.overrideMaterial = previousOverrideMaterial;
        this.scene.background = previousBackground;
        this.renderer.setClearColor(previousClearColor, previousClearAlpha);
        this.renderer.autoClear = previousAutoClear;
        this.renderer.setRenderTarget(previousRenderTarget);
        return true;
    }

    updateOccluders() {
        const revealEnabled = this.renderPlayerOcclusionMask();
        for (const occluder of this.occluders) {
            for (const material of [occluder.boxMesh.material, occluder.edgeMesh.material]) {
                const shader = material.userData.shader;
                if (shader) {
                    shader.uniforms.uRevealEnabled.value = 0;
                    shader.uniforms.uPlayerMaskTexture.value = this.playerOcclusionTarget.texture;
                    shader.uniforms.uPlayerDepthTexture.value = this.playerOcclusionTarget.depthTexture;
                    shader.uniforms.uRevealResolution.value.set(this.playerOcclusionTarget.width, this.playerOcclusionTarget.height);
                }
            }
            occluder.boxMesh.material.opacity = 1;
            occluder.edgeMesh.material.opacity = occluder.baseEdgeOpacity;
        }
        if (!revealEnabled) return;

        const subjects = [];
        if (this.playerObj?.visible) subjects.push(this.playerObj);
        for (const entity of this.entities) {
            if (entity.mesh?.visible) subjects.push(entity.mesh);
        }
        if (subjects.length === 0) return;

        const hitOccluders = new Set();
        for (const subject of subjects) {
            for (const samplePoint of this.getOcclusionSamplePointsForObject(subject)) {
                const dir = samplePoint.clone().sub(this.camera.position);
                const distance = dir.length();
                if (distance <= 0.01) continue;
                this.raycaster.set(this.camera.position, dir.normalize());
                this.raycaster.far = distance;
                const hits = this.raycaster.intersectObjects(this.occluders.map((item) => item.boxMesh), false);
                for (const hit of hits) {
                    const occluder = this.occluderLookup.get(hit.object.uuid);
                    if (occluder) hitOccluders.add(occluder);
                }
            }
        }

        for (const occluder of hitOccluders) {
            const boxShader = occluder.boxMesh.material.userData.shader;
            if (boxShader) boxShader.uniforms.uRevealEnabled.value = 1;
            const edgeShader = occluder.edgeMesh.material.userData.shader;
            if (edgeShader) edgeShader.uniforms.uRevealEnabled.value = 1;
        }
    }

    getOcclusionSamplePointsForObject(object3D) {
        object3D.updateWorldMatrix(true, true);
        const box = new THREE.Box3().setFromObject(object3D);
        if (box.isEmpty()) return [object3D.position.clone()];
        const sphere = box.getBoundingSphere(new THREE.Sphere());
        const center = sphere.center.clone();
        const right = new THREE.Vector3().setFromMatrixColumn(this.camera.matrixWorld, 0).normalize();
        const up = new THREE.Vector3().setFromMatrixColumn(this.camera.matrixWorld, 1).normalize();
        const radius = Math.max(0.12, sphere.radius * 0.9);
        const sampleOffsets = [
            [0, 0],
            [0, 0.62],
            [0, -0.62],
            [0.68, 0],
            [-0.68, 0],
            [0.46, 0.46],
            [-0.46, 0.46],
            [0.46, -0.46],
            [-0.46, -0.46]
        ];
        return sampleOffsets.map(([offsetX, offsetY]) => center.clone()
            .addScaledVector(right, radius * offsetX)
            .addScaledVector(up, radius * offsetY)
        );
    }

    buildPlayerModel() {
        const group = new THREE.Group();
        const body = new THREE.Group();
        const topRotor = new THREE.Group();
        const bottomRotor = new THREE.Group();
        topRotor.position.y = 0.12;
        bottomRotor.position.y = -0.1;

        const topDisk = this.tagEditableAssembly(this.createOutlinedAssembly(
            new THREE.CylinderGeometry(0.2, 0.55, 0.12, 32),
            this.materials.playerMain,
            0x0f172a
        ), 'player', 'top-disk', this.materials.playerMain.color, 0x0f172a);
        const bottomDisk = this.tagEditableAssembly(this.createOutlinedAssembly(
            new THREE.CylinderGeometry(0.55, 0.18, 0.12, 32),
            this.materials.playerShadow,
            0x020617
        ), 'player', 'bottom-disk', this.materials.playerShadow.color, 0x020617);
        const upperRing = this.tagEditableAssembly(this.createOutlinedAssembly(
            new THREE.TorusGeometry(0.4, 0.055, 12, 32),
            this.materials.playerAccent,
            0x0f172a
        ), 'player', 'upper-ring', this.materials.playerAccent.color, 0x0f172a);
        upperRing.rotation.x = Math.PI / 2;
        const lowerRing = this.tagEditableAssembly(this.createOutlinedAssembly(
            new THREE.TorusGeometry(0.34, 0.045, 10, 28),
            this.materials.playerMain,
            0x0f172a
        ), 'player', 'lower-ring', this.materials.playerMain.color, 0x0f172a);
        lowerRing.rotation.x = Math.PI / 2;

        const cabin = this.tagEditableAssembly(this.createOutlinedAssembly(
            new THREE.SphereGeometry(0.2, 20, 16, 0, Math.PI * 2, 0, Math.PI / 2),
            this.materials.playerCabin,
            0x38bdf8
        ), 'player', 'cabin', this.materials.playerCabin.color, 0x38bdf8);
        cabin.position.y = 0.19;

        const engineFinGeo = new THREE.BoxGeometry(0.08, 0.04, 0.28);
        for (let i = 0; i < 4; i++) {
            const fin = this.tagEditableAssembly(
                this.createOutlinedAssembly(engineFinGeo, this.materials.playerAccent, 0x082f49),
                'player',
                `fin-${i}`,
                this.materials.playerAccent.color,
                0x082f49
            );
            fin.position.set(Math.cos(i * Math.PI / 2) * 0.32, 0.01, Math.sin(i * Math.PI / 2) * 0.32);
            fin.rotation.y = i * Math.PI / 2;
            topRotor.add(fin);
        }

        const glowNodesGeo = new THREE.CylinderGeometry(0.04, 0.04, 0.08, 12);
        for (let i = 0; i < 3; i++) {
            const node = this.tagEditableAssembly(
                this.createOutlinedAssembly(glowNodesGeo, this.materials.playerCabin, 0x0f172a),
                'player',
                `node-${i}`,
                this.materials.playerCabin.color,
                0x0f172a
            );
            node.position.set(Math.cos(i * (Math.PI * 2 / 3)) * 0.22, -0.06, Math.sin(i * (Math.PI * 2 / 3)) * 0.22);
            node.rotation.z = Math.PI / 2;
            bottomRotor.add(node);
        }

        topRotor.add(topDisk, upperRing);
        bottomRotor.add(bottomDisk, lowerRing);
        body.add(topRotor, bottomRotor, cabin);
        group.add(body);
        return { group, body, topRotor, bottomRotor };
    }

    setupPlayer() {
        const built = this.buildPlayerModel();
        this.playerObj = built.group;
        this.playerBody = built.body;
        this.playerMesh = built.body;
        this.playerTopRotor = built.topRotor;
        this.playerBottomRotor = built.bottomRotor;
        this.enableOcclusionRevealLayer(this.playerObj);
        this.scene.add(this.playerObj);
        const playerBounds = new THREE.Box3().setFromObject(this.playerObj);
        this.playerRevealRadius = Math.max(0.42, playerBounds.getBoundingSphere(new THREE.Sphere()).radius * 0.92);
    }

    getPlayerRevealState() {
        if (!this.playerObj?.visible) return null;

        const center = this.playerObj.position.clone();
        const projectedCenter = center.clone().project(this.camera);
        if (!Number.isFinite(projectedCenter.x) || !Number.isFinite(projectedCenter.y) || projectedCenter.z < -1.2 || projectedCenter.z > 1.2) {
            return null;
        }

        const right = new THREE.Vector3().setFromMatrixColumn(this.camera.matrixWorld, 0).normalize();
        const up = new THREE.Vector3().setFromMatrixColumn(this.camera.matrixWorld, 1).normalize();
        const radius = this.playerRevealRadius;
        const projectedRight = center.clone().addScaledVector(right, radius).project(this.camera);
        const projectedLeft = center.clone().addScaledVector(right, -radius).project(this.camera);
        const projectedUp = center.clone().addScaledVector(up, radius).project(this.camera);
        const projectedDown = center.clone().addScaledVector(up, -radius).project(this.camera);
        const screenCenter = new THREE.Vector2(projectedCenter.x * 0.5 + 0.5, projectedCenter.y * 0.5 + 0.5);
        const radiusX = Math.max(Math.abs(projectedRight.x - projectedCenter.x), Math.abs(projectedLeft.x - projectedCenter.x)) * 0.5 * 1.18;
        const radiusY = Math.max(Math.abs(projectedUp.y - projectedCenter.y), Math.abs(projectedDown.y - projectedCenter.y)) * 0.5 * 1.24;

        return {
            center,
            right,
            up,
            radius,
            screenCenter,
            screenRadius: new THREE.Vector2(
                THREE.MathUtils.clamp(radiusX, 0.035, 0.22),
                THREE.MathUtils.clamp(radiusY, 0.035, 0.24)
            )
        };
    }

    getPlayerOcclusionSamplePoints(revealState) {
        const sampleOffsets = [
            [0, 0],
            [0, 0.62],
            [0, -0.7],
            [0.7, 0],
            [-0.7, 0],
            [0.46, 0.46],
            [-0.46, 0.46],
            [0.5, -0.42],
            [-0.5, -0.42],
            [0.28, 0.68],
            [-0.28, 0.68],
            [0.72, 0.24],
            [-0.72, 0.24],
            [0.28, -0.7],
            [-0.28, -0.7]
        ];
        return sampleOffsets.map(([offsetX, offsetY]) => revealState.center.clone()
            .addScaledVector(revealState.right, revealState.radius * offsetX)
            .addScaledVector(revealState.up, revealState.radius * offsetY)
        );
    }

    buildEnemyModel(archetype) {
        const group = new THREE.Group();
        const baseMat = new THREE.MeshBasicMaterial({ color: archetype.color });
        const accentMat = new THREE.MeshBasicMaterial({ color: archetype.accent });
        let spinGroup = null;
        let counterSpinGroup = null;

        if (archetype.id === 'scout') {
            const core = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.OctahedronGeometry(0.24), baseMat, 0x431407), archetype.id, 'core', baseMat.color, 0x431407);
            const ring = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.TorusGeometry(0.34, 0.03, 10, 28), accentMat, 0x7c2d12), archetype.id, 'ring', accentMat.color, 0x7c2d12);
            ring.rotation.x = Math.PI / 2;
            spinGroup = new THREE.Group();
            spinGroup.add(ring);
            group.add(core, spinGroup);
        } else if (archetype.id === 'brute') {
            const body = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.CylinderGeometry(0.28, 0.4, 0.48, 20), baseMat, 0x450a0a), archetype.id, 'body', baseMat.color, 0x450a0a);
            const cap = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.ConeGeometry(0.18, 0.22, 5), accentMat, 0x450a0a), archetype.id, 'cap', accentMat.color, 0x450a0a);
            cap.position.y = 0.34;
            group.add(body, cap);
            for (let i = 0; i < 4; i++) {
                const spike = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.ConeGeometry(0.07, 0.2, 4), accentMat, 0x450a0a), archetype.id, `spike-${i}`, accentMat.color, 0x450a0a);
                spike.position.set(Math.cos(i * Math.PI / 2) * 0.3, 0.08, Math.sin(i * Math.PI / 2) * 0.3);
                spike.rotation.z = Math.PI / 2;
                spike.rotation.y = i * Math.PI / 2;
                group.add(spike);
            }
        } else if (archetype.id === 'spine') {
            const spine = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.ConeGeometry(0.26, 0.6, 6), baseMat, 0x3b0764), archetype.id, 'spine', baseMat.color, 0x3b0764);
            spine.position.y = 0.1;
            const ring = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.TorusGeometry(0.26, 0.028, 8, 24), accentMat, 0x581c87), archetype.id, 'ring', accentMat.color, 0x581c87);
            ring.rotation.x = Math.PI / 2;
            ring.position.y = -0.02;
            spinGroup = new THREE.Group();
            spinGroup.add(ring);
            group.add(spine, spinGroup);
        } else if (archetype.id === 'warden') {
            const hub = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.IcosahedronGeometry(0.22, 0), baseMat, 0x042f2e), archetype.id, 'hub', baseMat.color, 0x042f2e);
            const halo = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.TorusGeometry(0.38, 0.04, 10, 30), accentMat, 0x134e4a), archetype.id, 'halo-horizontal', accentMat.color, 0x134e4a);
            halo.rotation.x = Math.PI / 2;
            spinGroup = new THREE.Group();
            counterSpinGroup = new THREE.Group();
            spinGroup.add(halo);
            const verticalHalo = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.TorusGeometry(0.28, 0.03, 10, 24), accentMat, 0x134e4a), archetype.id, 'halo-vertical', accentMat.color, 0x134e4a);
            verticalHalo.rotation.y = Math.PI / 2;
            counterSpinGroup.add(verticalHalo);
            group.add(hub, spinGroup, counterSpinGroup);
        } else if (archetype.id === 'boss') {
            const core = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.DodecahedronGeometry(0.35, 0), baseMat, 0x78350f), archetype.id, 'core', baseMat.color, 0x78350f);
            const outerRing = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.TorusGeometry(0.58, 0.055, 12, 40), accentMat, 0x92400e), archetype.id, 'outer-ring', accentMat.color, 0x92400e);
            outerRing.rotation.x = Math.PI / 2;
            const innerRing = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.TorusGeometry(0.4, 0.035, 10, 32), baseMat, 0x92400e), archetype.id, 'inner-ring', baseMat.color, 0x92400e);
            innerRing.rotation.y = Math.PI / 2;
            spinGroup = new THREE.Group();
            counterSpinGroup = new THREE.Group();
            spinGroup.add(outerRing);
            counterSpinGroup.add(innerRing);
            group.add(core, spinGroup, counterSpinGroup);
            for (let i = 0; i < 6; i++) {
                const shard = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.BoxGeometry(0.1, 0.22, 0.1), accentMat, 0x78350f), archetype.id, `shard-${i}`, accentMat.color, 0x78350f);
                shard.position.set(Math.cos(i * Math.PI / 3) * 0.55, Math.sin(i * Math.PI / 3) * 0.12, Math.sin(i * Math.PI / 3) * 0.55);
                group.add(shard);
            }
        }

        group.scale.setScalar(archetype.scale || 1);
        this.enableOcclusionRevealLayer(group);
        return { group, spinGroup, counterSpinGroup };
    }

    buildChestModel() {
        const group = new THREE.Group();
        const base = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.BoxGeometry(0.44, 0.24, 0.44), this.materials.chestDark, 0x451a03), 'chest', 'base', this.materials.chestDark.color, 0x451a03);
        const lid = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.BoxGeometry(0.48, 0.14, 0.48), this.materials.chest, 0x78350f), 'chest', 'lid', this.materials.chest.color, 0x78350f);
        lid.position.y = 0.16;
        const clasp = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.BoxGeometry(0.08, 0.12, 0.08), this.materials.playerCabin, 0x451a03), 'chest', 'clasp', this.materials.playerCabin.color, 0x451a03);
        clasp.position.set(0, 0.05, 0.24);
        group.add(base, lid, clasp);
        this.enableOcclusionRevealLayer(group);
        return { group };
    }

    buildExitModel() {
        const group = new THREE.Group();
        const plate = this.tagEditableAssembly(this.createOutlinedAssembly(new THREE.CylinderGeometry(0.3, 0.3, 0.1, 16), this.materials.end, 0x064e3b), 'exit', 'plate', this.materials.end.color, 0x064e3b);
        group.add(plate);
        this.enableOcclusionRevealLayer(group);
        return { group };
    }

    buildHiddenRoomMarker(kind, locked = false) {
        const palette = {
            treasure: { base: 0xfacc15, accent: 0xfef08a, edge: 0x713f12 },
            event: { base: 0x38bdf8, accent: 0xa5f3fc, edge: 0x164e63 },
            elite: { base: 0xfb7185, accent: 0xfda4af, edge: 0x881337 },
            vault: { base: 0xf59e0b, accent: 0xfef08a, edge: 0x78350f },
            merchant: { base: 0xa78bfa, accent: 0xe9d5ff, edge: 0x4c1d95 },
            gate: { base: 0x64748b, accent: 0xe2e8f0, edge: 0x0f172a }
        }[kind] || { base: 0x94a3b8, accent: 0xe2e8f0, edge: 0x0f172a };

        const group = new THREE.Group();
        const baseMat = new THREE.MeshBasicMaterial({ color: palette.base });
        const accentMat = new THREE.MeshBasicMaterial({ color: palette.accent });
        const base = this.createOutlinedAssembly(new THREE.CylinderGeometry(0.24, 0.28, 0.08, 12), baseMat, palette.edge);
        group.add(base);

        let icon;
        if (kind === 'treasure') {
            icon = this.createOutlinedAssembly(new THREE.OctahedronGeometry(0.18), accentMat, palette.edge);
            icon.position.y = 0.2;
        } else if (kind === 'event') {
            icon = this.createOutlinedAssembly(new THREE.IcosahedronGeometry(0.16, 0), accentMat, palette.edge);
            icon.position.y = 0.2;
            const ring = this.createOutlinedAssembly(new THREE.TorusGeometry(0.24, 0.03, 8, 20), baseMat, palette.edge);
            ring.rotation.x = Math.PI / 2;
            ring.position.y = 0.18;
            group.add(ring);
        } else if (kind === 'elite') {
            icon = this.createOutlinedAssembly(new THREE.ConeGeometry(0.16, 0.34, 4), accentMat, palette.edge);
            icon.position.y = 0.22;
            const ring = this.createOutlinedAssembly(new THREE.TorusGeometry(0.26, 0.03, 8, 18), baseMat, palette.edge);
            ring.rotation.x = Math.PI / 2;
            ring.position.y = 0.12;
            group.add(ring);
        } else if (kind === 'vault') {
            icon = this.createOutlinedAssembly(new THREE.BoxGeometry(0.22, 0.18, 0.22), accentMat, palette.edge);
            icon.position.y = 0.2;
            const crown = this.createOutlinedAssembly(new THREE.ConeGeometry(0.12, 0.2, 5), baseMat, palette.edge);
            crown.position.y = 0.38;
            group.add(crown);
        } else if (kind === 'merchant') {
            icon = this.createOutlinedAssembly(new THREE.BoxGeometry(0.18, 0.18, 0.18), accentMat, palette.edge);
            icon.position.y = 0.2;
            const halo = this.createOutlinedAssembly(new THREE.TorusGeometry(0.24, 0.035, 8, 18), baseMat, palette.edge);
            halo.rotation.y = Math.PI / 4;
            halo.position.y = 0.18;
            group.add(halo);
        } else {
            icon = this.createOutlinedAssembly(new THREE.BoxGeometry(0.18, 0.18, 0.18), accentMat, palette.edge);
            icon.position.y = 0.2;
        }
        group.add(icon);

        if (locked) {
            const lockMat = new THREE.MeshBasicMaterial({ color: 0xe2e8f0 });
            const barA = this.createOutlinedAssembly(new THREE.BoxGeometry(0.36, 0.04, 0.04), lockMat, 0x0f172a);
            const barB = this.createOutlinedAssembly(new THREE.BoxGeometry(0.36, 0.04, 0.04), lockMat, 0x0f172a);
            barA.position.y = 0.38;
            barB.position.y = 0.38;
            barA.rotation.z = Math.PI / 4;
            barB.rotation.z = -Math.PI / 4;
            group.add(barA, barB);
        }

        this.enableOcclusionRevealLayer(group);
        return { group };
    }

    buildEditableAsset(assetKey) {
        if (assetKey === 'player') return this.buildPlayerModel();
        if (assetKey === 'chest') return this.buildChestModel();
        if (assetKey === 'exit') return this.buildExitModel();
        const archetype = ENEMY_ARCHETYPES.find((enemy) => enemy.id === assetKey);
        return archetype ? this.buildEnemyModel(archetype) : this.buildPlayerModel();
    }

    shake(amount) {
        this.trauma = Math.min(this.trauma + amount, 1.0);
    }

    glitch(duration = 150) {
        this.glitchPass.enabled = true;
        setTimeout(() => { this.glitchPass.enabled = false; }, duration);
    }

    triggerUpgradeEffect() {
        this.shake(0.2);
        this.playerMesh.scale.set(1, 1, 1);
        this.tweens.add(this.playerMesh.scale, { x: 1.8, y: 1.8, z: 1.8 }, 0.2, Easing.easeOutQuad, () => {
            this.tweens.add(this.playerMesh.scale, { x: 1, y: 1, z: 1 }, 0.6, Easing.easeOutElastic);
        });
        this.spawnBurst(this.playerObj.position, 0x4ade80, 25, 4);
    }

    spawnBurst(pos, colorHex, count = 15, speedMultiplier = 1) {
        const geo = new THREE.PlaneGeometry(0.15, 0.15);
        const mat = new THREE.MeshBasicMaterial({ color: colorHex, side: THREE.DoubleSide });
        for (let i = 0; i < count; i++) {
            const particle = new THREE.Mesh(geo, mat);
            particle.position.copy(pos);
            particle.position.y += 0.2;
            const angle = Math.random() * Math.PI * 2;
            const speed = (Math.random() * 3 + 2) * speedMultiplier;
            particle.userData.velocity = new THREE.Vector3(Math.cos(angle) * speed, Math.random() * 5 + 2, Math.sin(angle) * speed);
            particle.userData.life = 1.0;
            this.scene.add(particle);
            this.particles.push(particle);
        }
    }

    addFloatingText(text, pos3D, colorStr, isCritical = false) {
        const el = document.createElement('div');
        el.className = 'floating-text';
        el.innerText = text;
        el.style.color = colorStr;
        if (isCritical) el.style.fontSize = '24px';
        this.textContainer.appendChild(el);
        this.floatingTexts.push({ el, pos: pos3D.clone().add(new THREE.Vector3(0, 1.5, 0)), life: 1.0, vy: 2.0 });
    }

    updateParticlesAndText(dt) {
        for (let i = this.particles.length - 1; i >= 0; i--) {
            const particle = this.particles[i];
            particle.userData.life -= dt * 1.5;
            if (particle.userData.life <= 0) {
                this.scene.remove(particle);
                this.particles.splice(i, 1);
                continue;
            }
            particle.userData.velocity.y -= 15 * dt;
            particle.position.addScaledVector(particle.userData.velocity, dt);
            particle.scale.setScalar(particle.userData.life);
            particle.quaternion.copy(this.camera.quaternion);
        }

        for (let i = this.floatingTexts.length - 1; i >= 0; i--) {
            const text = this.floatingTexts[i];
            text.life -= dt * 1.2;
            if (text.life <= 0) {
                text.el.remove();
                this.floatingTexts.splice(i, 1);
                continue;
            }
            text.pos.y += text.vy * dt;
            const temp = text.pos.clone();
            temp.project(this.camera);
            const x = (temp.x * 0.5 + 0.5) * this.canvas.clientWidth;
            const y = (temp.y * -0.5 + 0.5) * this.canvas.clientHeight;
            text.el.style.transform = `translate(-50%, -50%) translate(${x}px, ${y}px) scale(${text.life < 0.2 ? text.life * 5 : 1})`;
            text.el.style.opacity = text.life;
        }
    }

    updateEntityMotion(dt) {
        this.motionTime += dt;
        this.playerTopRotor.rotation.y += dt * 8.5;
        this.playerBottomRotor.rotation.y -= dt * 11.5;
        this.playerBody.position.y = Math.sin(this.motionTime * 3.4) * 0.03;

        for (const entity of this.entities) {
            if (!entity.mesh || entity.type === 'end') continue;
            const yTarget = entity.baseY + Math.sin(this.motionTime * entity.hoverSpeed + entity.hoverOffset) * entity.hoverAmplitude;
            entity.mesh.position.y = THREE.MathUtils.lerp(entity.mesh.position.y, yTarget, dt * 5);
            if (entity.spinGroup) entity.spinGroup.rotation.y += dt * entity.spinSpeed;
            if (entity.counterSpinGroup) entity.counterSpinGroup.rotation.y -= dt * entity.counterSpinSpeed;
        }
    }

    updateMovementAudio(dt) {
        if (!window.soundEngine) return;
        if (!this.playerObj?.visible || GameState.phase !== 'EXPLORING') {
            window.soundEngine.setMovementState(false);
            if (this.playerObj) this.lastPlayerAudioPos = this.playerObj.position.clone();
            return;
        }

        const currentPos = this.playerObj.position.clone();
        if (!this.lastPlayerAudioPos) {
            this.lastPlayerAudioPos = currentPos;
            return;
        }

        const delta = currentPos.clone().sub(this.lastPlayerAudioPos);
        const planarDistance = Math.hypot(delta.x, delta.z);
        const movementSpeed = dt > 0 ? planarDistance / dt : 0;
        const isMoving = planarDistance > 0.001 && movementSpeed > 0.2;
        const speedNorm = THREE.MathUtils.clamp(movementSpeed / 6, 0.55, 2.1);
        window.soundEngine.setMovementState(isMoving, speedNorm);
        this.lastPlayerAudioPos.copy(currentPos);
    }

    animate() {
        requestAnimationFrame(this.animate);
        const dt = Math.min(this.clock.getDelta(), 0.1);
        this.tweens.update(dt);
        this.updateParticlesAndText(dt);
        this.updateEntityMotion(dt);
        this.updateMovementAudio(dt);
        window.soundEngine?.update();

        if (this.playerObj) {
            const desiredCamPos = new THREE.Vector3();
            const desiredTarget = new THREE.Vector3();
            if (GameState.phase === 'COMBAT') {
                const pPos = this.playerObj.position;
                const currentEnemy = window.gameController?.currentEnemy;
                const enemyPos = currentEnemy ? currentEnemy.mesh.position : pPos.clone();
                const bossZoomOut = currentEnemy?.enemyData?.boss ? 1.4 : 1;
                desiredCamPos.set(pPos.x, 3.4 * bossZoomOut, pPos.z + 4.1 * bossZoomOut);
                desiredTarget.lerpVectors(pPos, enemyPos, 0.5);
                this.camera.fov = THREE.MathUtils.lerp(this.camera.fov, currentEnemy?.enemyData?.boss ? 48 : 45, dt * 5);
            } else if (GameState.phase === 'GENERATING') {
                desiredCamPos.set(0, 18, 4);
                desiredTarget.set(0, 0, 0);
                this.camera.fov = THREE.MathUtils.lerp(this.camera.fov, 55, dt * 2);
            } else if (GameState.phase === 'SELFTEST') {
                desiredCamPos.set(0, 2.85, 0.62);
                desiredTarget.set(0, 0.05, -1.12);
                this.camera.fov = THREE.MathUtils.lerp(this.camera.fov, 50, dt * 4);
            } else {
                const pPos = this.playerObj.position;
                desiredCamPos.set(pPos.x, 9, pPos.z + 4);
                desiredTarget.copy(pPos);
                this.camera.fov = THREE.MathUtils.lerp(this.camera.fov, 50, dt * 3);
            }

            this.camera.updateProjectionMatrix();
            this.camera.position.lerp(desiredCamPos, dt * 4);
            this.cameraTarget.lerp(desiredTarget, dt * 6);
            this.camera.lookAt(this.cameraTarget);

            if (this.trauma > 0) {
                const shakeAmt = this.trauma * this.trauma;
                this.camera.position.x += (Math.random() - 0.5) * shakeAmt;
                this.camera.position.y += (Math.random() - 0.5) * shakeAmt;
                this.camera.position.z += (Math.random() - 0.5) * shakeAmt;
                this.trauma = Math.max(0, this.trauma - dt * 2.5);
            }
        }

        this.updateOccluders();
        this.composer.render();
    }
}

class GameController {
    constructor(engine) {
        this.engine = engine;
        this.mazeGroup = new THREE.Group();
        this.engine.scene.add(this.mazeGroup);
        this.currentFloorProfile = FLOOR_ARCHETYPE_DEFS.combat;
        this.previousFloorTypeKey = 'combat';
        this.cols = GameState.getMazeDimensions().cols;
        this.rows = GameState.getMazeDimensions().rows;
        this.offsetC = -Math.floor(this.cols / 2);
        this.offsetR = -Math.floor(this.rows / 2);
        this.playerPos = { c: 0, r: 0 };
        this.endPos = { c: 0, r: 0 };
        this.path = [];
        this.genStack = [];
        this.currentEnemy = null;
        this.combatUiHideTimer = null;
        this.selfTestActive = false;
        this.hiddenRooms = [];
        this.floorKillCount = 0;
        this.hiddenRoomCounter = 0;
        this.activeHiddenRoomTargetId = null;
        this.tempFloorBuffs = { moveSpeedMult: 1, bonusDamageFlat: 0, hiddenBiasFlat: 0 };

        ['speed', 'atk', 'hp', 'chest', 'size', 'hidden', 'monster'].forEach((type) => {
            document.getElementById(`btn-up-${type}`).addEventListener('click', async () => {
                await window.soundEngine?.unlock();
                GameState.tryBuy(type);
            });
        });

        window.gameController = this;
        this.startLevel();
    }

    sleep(ms) {
        return new Promise((resolve) => setTimeout(resolve, ms));
    }

    showCombatUI() {
        const ui = document.getElementById('rpg-combat-ui');
        if (this.combatUiHideTimer) {
            clearTimeout(this.combatUiHideTimer);
            this.combatUiHideTimer = null;
        }
        ui.classList.remove('hidden');
        void ui.offsetWidth;
        ui.classList.remove('opacity-0');
        return ui;
    }

    hideCombatUI() {
        const ui = document.getElementById('rpg-combat-ui');
        if (this.combatUiHideTimer) {
            clearTimeout(this.combatUiHideTimer);
        }
        ui.classList.add('opacity-0');
        this.combatUiHideTimer = setTimeout(() => {
            ui.classList.add('hidden');
            this.combatUiHideTimer = null;
        }, 300);
        return ui;
    }

    getWorldPos(c, r) {
        return new THREE.Vector3(c + this.offsetC, 0, r + this.offsetR);
    }

    getMazeSizeBucket() {
        const side = this.cols;
        if (side <= 13) return 'small';
        if (side <= 19) return 'medium';
        return 'large';
    }

    rollFloorProfile() {
        if (GameState.level >= 4 && GameState.isBossUnlocked() && Math.random() < GameState.getBossFloorChance()) {
            return FLOOR_ARCHETYPE_DEFS.boss;
        }

        const entries = Object.values(FLOOR_ARCHETYPE_DEFS)
            .filter((profile) => profile.key !== 'boss')
            .map((profile) => {
                if (GameState.level < profile.minLevel) return { value: profile, weight: 0 };
                let weight = profile.weight;
                if (profile.key === this.previousFloorTypeKey) weight *= 0.38;
                if (profile.key === 'merchant' && GameState.score < 40 + GameState.level * 20) weight *= 0.55;
                return { value: profile, weight };
            })
            .filter((entry) => entry.weight > 0);
        return this.rollWeightedEntry(entries) || FLOOR_ARCHETYPE_DEFS.combat;
    }

    setCurrentFloorProfile(profile) {
        this.currentFloorProfile = profile || FLOOR_ARCHETYPE_DEFS.combat;
        this.previousFloorTypeKey = this.currentFloorProfile.key;
        GameState.currentFloor = {
            key: this.currentFloorProfile.key,
            label: this.currentFloorProfile.label,
            note: this.currentFloorProfile.note
        };
    }

    getEffectiveMazeSide() {
        const rawSide = GameState.getMazeSide() + (this.currentFloorProfile.sizeBias || 0) * 2;
        const clamped = THREE.MathUtils.clamp(rawSide, GameState.maze.baseSide, GameState.maze.maxSide);
        return clamped % 2 === 0 ? clamped - 1 : clamped;
    }

    getCell(c, r) {
        return this.grid?.[r]?.[c] || null;
    }

    getCellKey(c, r) {
        return `${c},${r}`;
    }

    isReservedSpecialCell(c, r) {
        const cell = this.getCell(c, r);
        if (!cell) return true;
        if ((c === 1 && r === 1) || (c === this.endPos.c && r === this.endPos.r)) return true;
        return !!cell.hiddenReservation;
    }

    countNearbyOccupiedCells(c, r, radius = 1) {
        let count = 0;
        for (let dr = -radius; dr <= radius; dr++) {
            for (let dc = -radius; dc <= radius; dc++) {
                if (dc === 0 && dr === 0) continue;
                const cell = this.getCell(c + dc, r + dr);
                if (!cell || cell.isWall) continue;
                if (cell.entity) count++;
            }
        }
        return count;
    }

    buildPathToTarget(startC, startR, goalFn) {
        const startKey = this.getCellKey(startC, startR);
        const queue = [{ c: startC, r: startR }];
        const visited = new Set([startKey]);
        const previous = new Map();
        const dirs = [[-1, 0], [1, 0], [0, -1], [0, 1]];

        while (queue.length > 0) {
            const curr = queue.shift();
            if (goalFn(curr.c, curr.r)) {
                const path = [];
                let key = this.getCellKey(curr.c, curr.r);
                while (key !== startKey) {
                    const [cStr, rStr] = key.split(',');
                    path.unshift({ c: Number(cStr), r: Number(rStr) });
                    key = previous.get(key);
                    if (!key) break;
                }
                return path;
            }

            for (const [dc, dr] of dirs) {
                const nc = curr.c + dc;
                const nr = curr.r + dr;
                const cell = this.getCell(nc, nr);
                if (!cell || cell.isWall) continue;
                const key = this.getCellKey(nc, nr);
                if (visited.has(key)) continue;
                visited.add(key);
                previous.set(key, this.getCellKey(curr.c, curr.r));
                queue.push({ c: nc, r: nr });
            }
        }

        return null;
    }

    findPath(target = null) {
        const goal = target
            ? (c, r) => c === target.c && r === target.r
            : (c, r) => c === this.endPos.c && r === this.endPos.r;
        this.path = this.buildPathToTarget(this.playerPos.c, this.playerPos.r, goal) || [];
        return this.path;
    }

    buildReachableDistanceMap() {
        const queue = [{ c: 1, r: 1, dist: 0 }];
        const visited = new Set([this.getCellKey(1, 1)]);
        const distances = new Map([[this.getCellKey(1, 1), 0]]);
        const dirs = [[-1, 0], [1, 0], [0, -1], [0, 1]];
        let maxDistance = 1;

        while (queue.length > 0) {
            const curr = queue.shift();
            maxDistance = Math.max(maxDistance, curr.dist);
            for (const [dc, dr] of dirs) {
                const nc = curr.c + dc;
                const nr = curr.r + dr;
                const cell = this.getCell(nc, nr);
                if (!cell || cell.isWall) continue;
                const key = this.getCellKey(nc, nr);
                if (visited.has(key)) continue;
                visited.add(key);
                distances.set(key, curr.dist + 1);
                queue.push({ c: nc, r: nr, dist: curr.dist + 1 });
            }
        }

        return { distances, maxDistance };
    }

    rollWeightedEntry(entries) {
        const total = entries.reduce((sum, entry) => sum + entry.weight, 0);
        if (total <= 0) return entries[0]?.value ?? null;
        let roll = Math.random() * total;
        for (const entry of entries) {
            roll -= entry.weight;
            if (roll <= 0) return entry.value;
        }
        return entries[entries.length - 1]?.value ?? null;
    }

    rollHiddenRoomCount() {
        const sideSpan = Math.max(1, GameState.maze.maxSide - GameState.maze.baseSide);
        const sizeProgress = THREE.MathUtils.clamp((this.cols - GameState.maze.baseSide) / sideSpan, 0, 1);
        const unlockBonus = GameState.getHiddenRoomSpawnBonus() + (this.currentFloorProfile.hiddenBonus || 0);
        const bucket = this.getMazeSizeBucket();
        let count = 0;
        if (Math.random() < 0.08 + sizeProgress * 0.24 + unlockBonus) count++;
        const canRollSecond = bucket !== 'small' && (GameState.maze.lvSize >= 3 || GameState.maze.lvHidden >= 4);
        if (canRollSecond && Math.random() < Math.max(0, -0.06 + sizeProgress * 0.12 + unlockBonus * 0.6)) count++;
        const roomCap = bucket === 'small' ? 1 : 2;
        const guaranteedMin = this.currentFloorProfile.guaranteedHiddenKinds?.length || 0;
        const profileCap = this.currentFloorProfile.maxHiddenRooms ?? roomCap;
        return Math.min(roomCap, profileCap, Math.max(count, guaranteedMin));
    }

    rollHiddenRoomType(existingKinds = []) {
        const entries = Object.entries(HIDDEN_ROOM_TYPE_DEFS).map(([kind, def]) => {
            let weight = def.weight;
            if (GameState.level < (def.minLevel || 1)) weight = 0;
            if (existingKinds.includes(kind)) weight *= 0.35;
            if (kind === 'elite' && existingKinds.includes('elite')) weight = 0;
            weight += this.currentFloorProfile.hiddenTypeWeights?.[kind] || 0;
            return { value: kind, weight };
        }).filter((entry) => entry.weight > 0);
        return this.rollWeightedEntry(entries);
    }

    rollHiddenRoomEvent() {
        const entries = HIDDEN_ROOM_EVENT_DEFS.map((eventDef) => ({ value: eventDef, weight: eventDef.weight }));
        return this.rollWeightedEntry(entries);
    }

    collectHiddenRoomCandidates(distanceMap, maxDistance) {
        const dirs = [[-1, 0], [1, 0], [0, -1], [0, 1]];
        const candidates = [];
        const seen = new Set();

        for (let r = 1; r < this.rows - 1; r++) {
            for (let c = 1; c < this.cols - 1; c++) {
                const anchor = this.getCell(c, r);
                if (!anchor || anchor.isWall) continue;
                const anchorDist = distanceMap.get(this.getCellKey(c, r)) || 0;

                for (const [dc, dr] of dirs) {
                    const corridor = this.getCell(c + dc, r + dr);
                    const room = this.getCell(c + dc * 2, r + dr * 2);
                    if (!corridor || !room || !corridor.isWall || !room.isWall) continue;
                    if (this.isReservedSpecialCell(c + dc, r + dr) || this.isReservedSpecialCell(c + dc * 2, r + dr * 2)) continue;
                    const roomKey = this.getCellKey(c + dc * 2, r + dr * 2);
                    if (seen.has(roomKey)) continue;
                    seen.add(roomKey);
                    const roomC = c + dc * 2;
                    const roomR = r + dr * 2;
                    const startDistance = Math.abs(roomC - 1) + Math.abs(roomR - 1);
                    const exitDistance = Math.abs(roomC - this.endPos.c) + Math.abs(roomR - this.endPos.r);
                    candidates.push({
                        anchorC: c,
                        anchorR: r,
                        corridorC: c + dc,
                        corridorR: r + dr,
                        roomC,
                        roomR,
                        difficulty: anchorDist / Math.max(1, maxDistance),
                        nearbyEntityCount: this.countNearbyOccupiedCells(c, r, 1),
                        startDistance,
                        exitDistance,
                        anchorHasEntity: !!anchor.entity
                    });
                }
            }
        }

        return candidates;
    }

    isCandidateTooCloseToUsed(candidate, usedRooms) {
        for (const used of usedRooms) {
            const distance = Math.abs(candidate.roomC - used.roomC) + Math.abs(candidate.roomR - used.roomR);
            if (distance <= 4) return true;
        }
        return false;
    }

    pickHiddenRoomCandidate(candidates, kind, usedKeys) {
        const targetRange = kind === 'vault'
            ? [0.72, 1]
            : kind === 'elite'
            ? [0.55, 1]
            : kind === 'event'
                ? [0.35, 0.85]
                : [0.18, 0.72];

        let best = null;
        let bestScore = -Infinity;
        for (const candidate of candidates) {
            const roomKey = this.getCellKey(candidate.roomC, candidate.roomR);
            if (usedKeys.has(roomKey)) continue;
            const corridorKey = this.getCellKey(candidate.corridorC, candidate.corridorR);
            if (usedKeys.has(corridorKey)) continue;
            if (candidate.startDistance <= 3 || candidate.exitDistance <= 2) continue;
            const inRange = candidate.difficulty >= targetRange[0] && candidate.difficulty <= targetRange[1];
            const rangeCenter = (targetRange[0] + targetRange[1]) * 0.5;
            const closeness = 1 - Math.abs(candidate.difficulty - rangeCenter);
            const occupancyPenalty = candidate.nearbyEntityCount * 0.18;
            const anchorPenalty = candidate.anchorHasEntity ? 0.14 : 0;
            const depthBonus = Math.min(0.3, candidate.startDistance * 0.02);
            const score = (inRange ? 0.65 : 0) + closeness + depthBonus - occupancyPenalty - anchorPenalty + Math.random() * 0.25;
            if (score > bestScore) {
                best = candidate;
                bestScore = score;
            }
        }
        return best;
    }

    getHiddenRoomGateInfo(kind) {
        const gateKey = this.rollWeightedEntry(HIDDEN_ROOM_TYPE_DEFS[kind].gatePool.map((key) => ({ value: key, weight: 1 })));
        const gateDef = HIDDEN_ROOM_GATE_DEFS[gateKey] || HIDDEN_ROOM_GATE_DEFS.none;
        const bucket = this.getMazeSizeBucket();
        return {
            gateKey,
            gateType: gateDef.type,
            killsRequired: gateDef.threshold[bucket] || 0
        };
    }

    createFloatingMarkerEntity(build, c, r, type, extra = {}) {
        const pos = this.getWorldPos(c, r);
        build.group.position.set(pos.x, 5, pos.z);
        this.engine.scene.add(build.group);
        const targetY = extra.targetY ?? 0.26;
        this.engine.tweens.add(build.group.position, { y: targetY }, 0.5, Easing.easeOutBounce);
        return {
            type,
            mesh: build.group,
            c,
            r,
            baseY: targetY,
            hoverAmplitude: extra.hoverAmplitude ?? 0.03,
            hoverSpeed: extra.hoverSpeed ?? 1.8,
            hoverOffset: Math.random() * Math.PI * 2,
            spinSpeed: extra.spinSpeed ?? 1.1,
            counterSpinSpeed: 0,
            spinGroup: build.group,
            counterSpinGroup: null,
            ...extra
        };
    }

    removeSceneEntity(entityObj) {
        if (!entityObj) return;
        this.engine.scene.remove(entityObj.mesh);
        const entityIndex = this.engine.entities.findIndex((entity) => entity === entityObj);
        if (entityIndex > -1) this.engine.entities.splice(entityIndex, 1);
    }

    getHiddenRoomRewardScore(room) {
        return Math.floor((18 + room.rewardTier * 18) * GameState.level);
    }

    spawnFloorFeatureEntity(kind, c, r, extra = {}) {
        const marker = this.createFloatingMarkerEntity(
            this.engine.buildHiddenRoomMarker(kind),
            c,
            r,
            `${kind}_site`,
            {
                hoverAmplitude: 0.05,
                hoverSpeed: 1.8,
                spinSpeed: kind === 'merchant' ? 0.85 : 1.3,
                ...extra
            }
        );
        this.engine.entities.push(marker);
        const cell = this.getCell(c, r);
        if (cell) cell.entity = marker.type;
        return marker;
    }

    pickMainRouteSpecialCell(mainPath, progress = 0.62) {
        if (!Array.isArray(mainPath) || mainPath.length < 4) return null;
        const startIndex = THREE.MathUtils.clamp(Math.floor(mainPath.length * progress), 1, mainPath.length - 2);
        for (let offset = 0; offset < mainPath.length; offset++) {
            const forward = mainPath[startIndex + offset];
            if (forward) {
                const cell = this.getCell(forward.c, forward.r);
                if (cell && !cell.entity && !(forward.c === this.endPos.c && forward.r === this.endPos.r)) return cell;
            }
            const backward = mainPath[startIndex - offset];
            if (backward) {
                const cell = this.getCell(backward.c, backward.r);
                if (cell && !cell.entity && !(backward.c === this.endPos.c && backward.r === this.endPos.r)) return cell;
            }
        }
        return null;
    }

    tryResolveMerchantOffer() {
        const unopenedHiddenCount = this.hiddenRooms.filter((room) => !room.cleared && !room.unlocked).length;
        const offers = [
            {
                key: 'repair',
                cost: Math.floor(22 + GameState.level * 12),
                condition: () => GameState.player.currentHp < GameState.player.baseHp * 0.78,
                apply: () => {
                    const heal = Math.max(8, Math.floor(GameState.player.baseHp * 0.32));
                    GameState.player.currentHp = Math.min(GameState.player.baseHp, GameState.player.currentHp + heal);
                    return { title: 'Repair', subtitle: `HP +${heal}`, color: '#34d399' };
                }
            },
            {
                key: 'overclock',
                cost: Math.floor(36 + GameState.level * 14),
                condition: () => true,
                apply: () => {
                    this.tempFloorBuffs.bonusDamageFlat += 8;
                    return { title: 'Overclock', subtitle: 'ATK +8', color: '#f87171' };
                }
            },
            {
                key: 'scanner',
                cost: Math.floor(28 + GameState.level * 10),
                condition: () => unopenedHiddenCount > 0,
                apply: () => {
                    this.unlockAllHiddenRoomGates();
                    this.tempFloorBuffs.hiddenBiasFlat = Math.max(this.tempFloorBuffs.hiddenBiasFlat, 0.12);
                    return { title: 'Scanner', subtitle: 'Open hidden rooms', color: '#22d3ee' };
                }
            },
            {
                key: 'thruster',
                cost: Math.floor(24 + GameState.level * 9),
                condition: () => true,
                apply: () => {
                    this.tempFloorBuffs.moveSpeedMult = Math.min(this.tempFloorBuffs.moveSpeedMult, 0.72);
                    return { title: 'Thrusters', subtitle: 'Move faster', color: '#34d399' };
                }
            }
        ].filter((offer) => offer.condition());

        const affordable = offers.find((offer) => GameState.score >= offer.cost);
        if (affordable && GameState.spendScore(affordable.cost)) {
            const result = affordable.apply();
            return { ...result, cost: affordable.cost, spent: true };
        }

        const freeReward = Math.floor(14 * GameState.level);
        GameState.addScore(freeReward);
        return { title: 'Supply', subtitle: `Score +${freeReward}`, color: '#facc15', spent: false };
    }

    buildEliteRoomArchetype() {
        const base = this.pickEnemyArchetype();
        return {
            ...base,
            name: `缂侇喗宕樼€?${base.name}`,
            baseHp: Math.floor(base.baseHp * 1.75),
            baseAtk: Math.floor(base.baseAtk * 1.35),
            reward: Math.floor(base.reward * 1.8),
            scale: (base.scale || 1) * 1.12,
            hiddenElite: true
        };
    }

    spawnHiddenRoomEntity(room) {
        const cell = this.getCell(room.c, room.r);
        if (!cell || room.cleared) return;

        if (room.kind === 'elite') {
            const elite = this.createMonsterEntity(this.buildEliteRoomArchetype(), room.c, room.r);
            elite.hiddenRoomId = room.id;
            elite.hiddenRoomBonusScore = Math.floor(this.getHiddenRoomRewardScore(room) * 1.25);
            this.engine.entities.push(elite);
            cell.entity = 'monster';
            return;
        }

        const marker = this.createFloatingMarkerEntity(
            this.engine.buildHiddenRoomMarker(room.kind),
            room.c,
            room.r,
            `hidden_${room.kind}`,
            {
                hiddenRoomId: room.id,
                hoverAmplitude: 0.045,
                hoverSpeed: 2.1,
                spinSpeed: room.kind === 'event' ? 1.8 : 1.2
            }
        );
        this.engine.entities.push(marker);
        cell.entity = marker.type;
    }

    createHiddenGateMarker(room) {
        const marker = this.createFloatingMarkerEntity(
            this.engine.buildHiddenRoomMarker('gate', true),
            room.c,
            room.r,
            'hidden_gate',
            {
                hiddenRoomId: room.id,
                targetY: 0.56,
                hoverAmplitude: 0.02,
                hoverSpeed: 1.4,
                spinSpeed: 0.5
            }
        );
        this.engine.entities.push(marker);
        room.gateMarker = marker;
    }

    openHiddenRoom(room, reason = 'unlock') {
        if (!room || room.unlocked || room.cleared) return false;
        const roomCell = this.getCell(room.c, room.r);
        if (!roomCell || !roomCell.isWall) return false;
        this.digWall(roomCell);
        room.unlocked = true;
        if (room.gateMarker) {
            this.removeSceneEntity(room.gateMarker);
            room.gateMarker = null;
        }
        this.spawnHiddenRoomEntity(room);
        const revealPos = this.getWorldPos(room.c, room.r);
        this.engine.addFloatingText(reason === 'event' ? '閻庨潧妫楅濠氬绩瑜版帊澹? : '閻庨潧妫楅璇差嚕閳ь剟宕?, revealPos, '#5eead4');
        return true;
    }

    updateHiddenRoomGates(reason = 'kills') {
        let opened = 0;
        for (const room of this.hiddenRooms) {
            if (room.unlocked || room.cleared || room.gateType !== 'kills_this_floor') continue;
            if (this.floorKillCount >= room.killsRequired && this.openHiddenRoom(room, reason)) opened++;
        }
        return opened;
    }

    unlockAllHiddenRoomGates() {
        let opened = 0;
        for (const room of this.hiddenRooms) {
            if (room.unlocked || room.cleared) continue;
            if (this.openHiddenRoom(room, 'event')) opened++;
        }
        return opened;
    }

    createHiddenRooms() {
        const hiddenRoomCount = this.rollHiddenRoomCount();
        if (hiddenRoomCount <= 0) return;

        const { distances, maxDistance } = this.buildReachableDistanceMap();
        const candidates = this.collectHiddenRoomCandidates(distances, maxDistance);
        if (candidates.length === 0) return;

        const usedKeys = new Set();
        const usedRooms = [];
        const existingKinds = [];
        const plannedKinds = [...(this.currentFloorProfile.guaranteedHiddenKinds || [])];
        const plannedExistingKinds = [...plannedKinds];
        while (plannedKinds.length < hiddenRoomCount) {
            const kind = this.rollHiddenRoomType(plannedExistingKinds);
            if (!kind) break;
            plannedKinds.push(kind);
            plannedExistingKinds.push(kind);
        }

        for (let i = 0; i < hiddenRoomCount; i++) {
            const kind = plannedKinds[i];
            if (!kind) break;
            const candidate = this.pickHiddenRoomCandidate(
                candidates.filter((item) => !this.isCandidateTooCloseToUsed(item, usedRooms)),
                kind,
                usedKeys
            );
            if (!candidate) break;

            usedKeys.add(this.getCellKey(candidate.corridorC, candidate.corridorR));
            usedKeys.add(this.getCellKey(candidate.roomC, candidate.roomR));
            usedRooms.push(candidate);
            existingKinds.push(kind);

            const corridorCell = this.getCell(candidate.corridorC, candidate.corridorR);
            if (!corridorCell) continue;
            corridorCell.hiddenReservation = true;
            const roomCell = this.getCell(candidate.roomC, candidate.roomR);
            if (!roomCell) continue;
            roomCell.hiddenReservation = true;

            this.digWall(corridorCell);

            const gateInfo = this.getHiddenRoomGateInfo(kind);
            const room = {
                id: ++this.hiddenRoomCounter,
                kind,
                rewardTier: HIDDEN_ROOM_TYPE_DEFS[kind].rewardTier,
                autoBias: HIDDEN_ROOM_TYPE_DEFS[kind].autoBias,
                c: candidate.roomC,
                r: candidate.roomR,
                entryC: candidate.corridorC,
                entryR: candidate.corridorR,
                gateType: gateInfo.gateType,
                killsRequired: gateInfo.killsRequired,
                unlocked: gateInfo.gateType === 'none',
                cleared: false,
                difficulty: candidate.difficulty,
                eventDef: kind === 'event' ? this.rollHiddenRoomEvent() : null,
                gateMarker: null
            };

            this.hiddenRooms.push(room);
            if (room.unlocked) {
                this.digWall(roomCell);
                this.spawnHiddenRoomEntity(room);
            } else {
                this.createHiddenGateMarker(room);
            }
        }
    }

    createFloorFeature(mainPath) {
        if (this.currentFloorProfile.key === 'merchant') {
            const cell = this.pickMainRouteSpecialCell(mainPath, 0.55);
            if (cell) this.spawnFloorFeatureEntity('merchant', cell.c, cell.r, { hoverAmplitude: 0.04, hoverSpeed: 1.55, spinSpeed: 0.7 });
        }
    }

    spawnBossOnMainPath(mainPath) {
        const bossArchetype = ENEMY_ARCHETYPES.find((enemy) => enemy.id === 'boss');
        if (!bossArchetype || !Array.isArray(mainPath) || mainPath.length === 0) return;
        const preferredIndex = THREE.MathUtils.clamp(mainPath.length - 3, 0, mainPath.length - 1);
        let bossNode = null;
        for (let offset = 0; offset < mainPath.length; offset++) {
            const candidate = mainPath[preferredIndex - offset];
            if (!candidate) continue;
            if (candidate.c === 1 && candidate.r === 1) continue;
            if (candidate.c === this.endPos.c && candidate.r === this.endPos.r) continue;
            const cell = this.getCell(candidate.c, candidate.r);
            if (!cell || cell.entity) continue;
            bossNode = candidate;
            break;
        }
        if (!bossNode) return;
        const boss = this.createMonsterEntity(bossArchetype, bossNode.c, bossNode.r);
        this.engine.entities.push(boss);
        this.getCell(bossNode.c, bossNode.r).entity = 'monster';
    }

    pickBestHiddenRoomTarget() {
        const pathToExit = this.buildPathToTarget(this.playerPos.c, this.playerPos.r, (c, r) => c === this.endPos.c && r === this.endPos.r);
        const exitLength = pathToExit ? pathToExit.length : Infinity;
        let best = null;

        for (const room of this.hiddenRooms) {
            if (!room.unlocked || room.cleared) continue;
            const pathToRoom = this.buildPathToTarget(this.playerPos.c, this.playerPos.r, (c, r) => c === room.c && r === room.r);
            if (!pathToRoom || pathToRoom.length === 0) continue;
            const pathRoomToExit = this.buildPathToTarget(room.c, room.r, (c, r) => c === this.endPos.c && r === this.endPos.r);
            if (!pathRoomToExit) continue;

            const detour = Math.max(0, pathToRoom.length + pathRoomToExit.length - exitLength);
            const detourNorm = detour / Math.max(6, this.cols + this.rows);
            const targetLockBonus = this.activeHiddenRoomTargetId === room.id ? 0.08 : 0;
            const accessScore = room.rewardTier * 0.17 + room.autoBias + GameState.getHiddenRoomDiversionBonus() + (this.tempFloorBuffs.hiddenBiasFlat || 0) + targetLockBonus - detourNorm * 0.7;
            if (!best || accessScore > best.accessScore) best = { room, pathToRoom, accessScore };
        }

        const threshold = 0.34;
        return best && best.accessScore >= threshold ? best : null;
    }

    refreshAutoPath() {
        const hiddenTarget = this.pickBestHiddenRoomTarget();
        if (hiddenTarget) {
            this.path = hiddenTarget.pathToRoom;
            this.activeHiddenRoomTargetId = hiddenTarget.room.id;
            return;
        }
        this.activeHiddenRoomTargetId = null;
        this.findPath();
    }

    runOcclusionSelfTest(mode = 'player') {
        this.selfTestActive = true;
        clearInterval(this.genInterval);
        clearTimeout(this.combatUiHideTimer);
        this.hideCombatUI();
        this.path = [];
        this.hiddenRooms = [];
        this.floorKillCount = 0;
        this.hiddenRoomCounter = 0;
        this.activeHiddenRoomTargetId = null;
        this.tempFloorBuffs = { moveSpeedMult: 1, bonusDamageFlat: 0, hiddenBiasFlat: 0 };
        this.exploreNext = () => {};
        this.currentEnemy = null;
        this.engine.tweens.tweens = [];

        while (this.mazeGroup.children.length > 0) this.mazeGroup.remove(this.mazeGroup.children[0]);
        this.engine.entities.forEach((entity) => this.engine.scene.remove(entity.mesh));
        this.engine.entities = [];
        this.engine.occluders = [];
        this.engine.occluderLookup.clear();

        const floor = new THREE.Mesh(new THREE.PlaneGeometry(8, 8), this.engine.materials.floor);
        floor.rotation.x = -Math.PI / 2;
        floor.position.y = 0;
        this.mazeGroup.add(floor);

        const wallGeo = new THREE.BoxGeometry(1, 0.5, 1);
        const edgesGeo = new THREE.EdgesGeometry(wallGeo);
        const primaryWall = this.engine.createWallCell(wallGeo, edgesGeo, new THREE.Vector3(0, 0, -0.92));
        this.mazeGroup.add(primaryWall);
        const sideWall = this.engine.createWallCell(wallGeo, edgesGeo, new THREE.Vector3(1.05, 0, -0.18));
        this.mazeGroup.add(sideWall);

        const testChest = this.createChestEntity(1, 1);
        testChest.mesh.position.set(0, -0.02, -1.12);
        testChest.baseY = -0.02;
        testChest.mesh.visible = mode === 'chest';
        this.engine.entities.push(testChest);

        this.engine.playerObj.position.set(0, -0.18, -1.12);
        this.engine.playerObj.visible = mode === 'player';
        this.engine.lastPlayerAudioPos = this.engine.playerObj.position.clone();

        GameState.phase = 'SELFTEST';
        GameState.updateUI();
        document.body.dataset.selftestReady = '1';
    }

    startLevel() {
        if (this.selfTestActive) return;
        GameState.phase = 'GENERATING';
        this.setCurrentFloorProfile(this.rollFloorProfile());
        GameState.updateUI();
        this.cols = this.getEffectiveMazeSide();
        this.rows = this.cols;
        this.offsetC = -Math.floor(this.cols / 2);
        this.offsetR = -Math.floor(this.rows / 2);

        while (this.mazeGroup.children.length > 0) this.mazeGroup.remove(this.mazeGroup.children[0]);
        this.engine.entities.forEach((entity) => this.engine.scene.remove(entity.mesh));
        this.engine.entities = [];
        this.engine.occluders = [];
        this.engine.occluderLookup.clear();
        this.grid = [];
        this.hiddenRooms = [];
        this.floorKillCount = 0;
        this.hiddenRoomCounter = 0;
        this.activeHiddenRoomTargetId = null;
        this.tempFloorBuffs = { moveSpeedMult: 1, bonusDamageFlat: 0, hiddenBiasFlat: 0 };

        const floorGeo = new THREE.PlaneGeometry(this.cols + 2, this.rows + 2);
        const floorMesh = new THREE.Mesh(floorGeo, this.engine.materials.floor);
        floorMesh.rotation.x = -Math.PI / 2;
        floorMesh.position.y = 0;
        this.mazeGroup.add(floorMesh);

        const wallGeo = new THREE.BoxGeometry(1, 0.5, 1);
        const edgesGeo = new THREE.EdgesGeometry(wallGeo);
        for (let r = 0; r < this.rows; r++) {
            const row = [];
            for (let c = 0; c < this.cols; c++) {
                const pos = this.getWorldPos(c, r);
                const group = this.engine.createWallCell(wallGeo, edgesGeo, pos);
                this.mazeGroup.add(group);
                row.push({ c, r, isWall: true, mesh: group, visited: false, entity: null, hiddenReservation: false });
            }
            this.grid.push(row);
        }

        this.playerPos = { c: 1, r: 1 };
        this.endPos = { c: this.cols - 2, r: this.rows - 2 };
        this.grid[1][1].visited = true;
        this.genStack = [this.grid[1][1]];
        this.engine.playerObj.visible = false;
        this.genInterval = setInterval(() => this.stepGenerate(), 20);
    }

    shuffleCells(cells) {
        for (let i = cells.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [cells[i], cells[j]] = [cells[j], cells[i]];
        }
        return cells;
    }

    getSpawnTargets(openCellCount) {
        if (this.currentFloorProfile.key === 'boss') return { monsters: 0, chests: 0 };
        const side = this.cols;
        const sideSpan = Math.max(1, GameState.maze.maxSide - GameState.maze.baseSide);
        const sizeProgress = THREE.MathUtils.clamp((side - GameState.maze.baseSide) / sideSpan, 0, 1);

        // Small mazes keep more breathing room; larger mazes can spend more of their open cells on content.
        const placementBudgetRatio = 0.12 + sizeProgress * 0.16;
        const placementBudget = Math.min(
            Math.max(0, openCellCount - 1),
            Math.floor(openCellCount * placementBudgetRatio)
        );
        if (placementBudget <= 0) return { monsters: 0, chests: 0 };

        const monsterDensity = GameState.maze.baseMonsterRate * (0.78 + sizeProgress * 0.45) * (0.58 + sizeProgress * 0.42) * (this.currentFloorProfile.monsterMul || 1);
        const chestDensity = GameState.maze.baseChestRate * (0.72 + sizeProgress * 0.4) * (0.58 + sizeProgress * 0.42) * (this.currentFloorProfile.chestMul || 1);
        const monsterTarget = Math.round(openCellCount * monsterDensity);
        const chestTarget = Math.round(openCellCount * chestDensity);

        let monsters = monsterTarget;
        let chests = chestTarget;
        const totalTargets = monsterTarget + chestTarget;

        if (totalTargets > placementBudget) {
            const monsterShare = totalTargets > 0 ? monsterTarget / totalTargets : 0.5;
            monsters = Math.min(monsterTarget, Math.round(placementBudget * monsterShare));
            chests = Math.min(chestTarget, placementBudget - monsters);

            const remainder = placementBudget - monsters - chests;
            if (remainder > 0) {
                if (monsterTarget - monsters >= chestTarget - chests) monsters += remainder;
                else chests += remainder;
            }
        }

        if (monsters === 0 && GameState.maze.lvMonster > 0 && placementBudget > 0) monsters = 1;
        if (chests === 0 && GameState.maze.lvChest > 0 && placementBudget - monsters > 0) chests = 1;

        if (monsters + chests > placementBudget) {
            if (chests > monsters) chests = Math.max(0, placementBudget - monsters);
            else monsters = Math.max(0, placementBudget - chests);
        }
        return { monsters, chests };
    }

    digWall(cell) {
        if (!cell.isWall) return;
        cell.isWall = false;
        this.engine.tweens.add(cell.mesh.position, { y: -0.5 }, 0.3, Easing.easeOutQuad);
        if (Math.random() > 0.5) {
            this.engine.spawnBurst(new THREE.Vector3(cell.mesh.position.x, 0, cell.mesh.position.z), 0x475569, 3, 0.5);
        }
    }

    stepGenerate() {
        if (this.selfTestActive) return;
        if (this.genStack.length === 0) {
            clearInterval(this.genInterval);
            this.finishGeneration();
            return;
        }

        let steps = 3;
        while (steps-- > 0 && this.genStack.length > 0) {
            const curr = this.genStack[this.genStack.length - 1];
            this.digWall(curr);
            const neighbors = [];
            const dirs = [[-2, 0], [2, 0], [0, -2], [0, 2]];

            for (const dir of dirs) {
                const nc = curr.c + dir[0];
                const nr = curr.r + dir[1];
                if (nc > 0 && nc < this.cols - 1 && nr > 0 && nr < this.rows - 1 && !this.grid[nr][nc].visited) {
                    neighbors.push({ c: nc, r: nr, wc: curr.c + dir[0] / 2, wr: curr.r + dir[1] / 2 });
                }
            }

            if (neighbors.length > 0) {
                const next = neighbors[Math.floor(Math.random() * neighbors.length)];
                this.digWall(this.grid[next.wr][next.wc]);
                this.grid[next.r][next.c].visited = true;
                this.genStack.push(this.grid[next.r][next.c]);
            } else {
                this.genStack.pop();
            }
        }
    }

    pickEnemyArchetype() {
        const pool = ENEMY_ARCHETYPES.filter((enemy) => !enemy.boss && GameState.level >= enemy.minLevel);
        const totalWeight = pool.reduce((sum, enemy) => sum + enemy.weight, 0);
        let roll = Math.random() * totalWeight;
        for (const enemy of pool) {
            roll -= enemy.weight;
            if (roll <= 0) return enemy;
        }
        return pool[pool.length - 1];
    }

    createChestEntity(c, r) {
        const built = this.engine.buildChestModel();
        const pos = this.getWorldPos(c, r);
        built.group.position.set(pos.x, 5, pos.z);
        this.engine.scene.add(built.group);
        this.engine.tweens.add(built.group.position, { y: 0.25 }, 0.6, Easing.easeOutBounce);
        return {
            type: 'chest',
            mesh: built.group,
            c,
            r,
            baseY: 0.25,
            hoverAmplitude: 0.04,
            hoverSpeed: 1.5,
            hoverOffset: Math.random() * Math.PI * 2,
            spinSpeed: 0.7,
            counterSpinSpeed: 0,
            spinGroup: built.group,
            counterSpinGroup: null
        };
    }

    createMonsterEntity(archetype, c, r) {
        const built = this.engine.buildEnemyModel(archetype);
        const pos = this.getWorldPos(c, r);
        built.group.position.set(pos.x, 5, pos.z);
        this.engine.scene.add(built.group);
        this.engine.tweens.add(built.group.position, { y: 0.25 }, 0.6, Easing.easeOutBounce);
        return {
            type: 'monster',
            mesh: built.group,
            c,
            r,
            enemyData: archetype,
            baseY: 0.25,
            hoverAmplitude: archetype.hoverAmplitude,
            hoverSpeed: archetype.hoverSpeed,
            hoverOffset: Math.random() * Math.PI * 2,
            spinSpeed: archetype.boss ? 1.9 : 2.6,
            counterSpinSpeed: archetype.boss ? 2.7 : 3.6,
            spinGroup: built.spinGroup,
            counterSpinGroup: built.counterSpinGroup
        };
    }

    finishGeneration() {
        this.digWall(this.grid[this.endPos.r][this.endPos.c]);
        const mainPath = this.buildPathToTarget(1, 1, (c, r) => c === this.endPos.c && r === this.endPos.r) || [];
        const openCells = [];

        for (let r = 1; r < this.rows - 1; r++) {
            for (let c = 1; c < this.cols - 1; c++) {
                if ((r === 1 && c === 1) || (r === this.endPos.r && c === this.endPos.c) || this.grid[r][c].isWall) continue;
                openCells.push(this.grid[r][c]);
            }
        }

        const shuffledCells = this.shuffleCells([...openCells]);
        const spawnTargets = this.getSpawnTargets(shuffledCells.length);
        let spawnCursor = 0;

        for (let i = 0; i < spawnTargets.monsters && spawnCursor < shuffledCells.length; i++, spawnCursor++) {
            const cell = shuffledCells[spawnCursor];
            const monster = this.createMonsterEntity(this.pickEnemyArchetype(), cell.c, cell.r);
            this.engine.entities.push(monster);
            cell.entity = 'monster';
        }

        for (let i = 0; i < spawnTargets.chests && spawnCursor < shuffledCells.length; i++, spawnCursor++) {
            const cell = shuffledCells[spawnCursor];
            const chest = this.createChestEntity(cell.c, cell.r);
            this.engine.entities.push(chest);
            cell.entity = 'chest';
        }

        this.createHiddenRooms();
        this.createFloorFeature(mainPath);
        if (this.currentFloorProfile.key === 'boss') this.spawnBossOnMainPath(mainPath);

        const endBuilt = this.engine.buildExitModel();
        const endWp = this.getWorldPos(this.endPos.c, this.endPos.r);
        endBuilt.group.position.set(endWp.x, 0.06, endWp.z);
        this.engine.scene.add(endBuilt.group);
        this.engine.entities.push({ type: 'end', mesh: endBuilt.group, c: this.endPos.c, r: this.endPos.r, baseY: 0.06, hoverAmplitude: 0, hoverSpeed: 0, hoverOffset: 0 });
        this.grid[this.endPos.r][this.endPos.c].entity = 'end';

        this.findPath();
        const pStart = this.getWorldPos(1, 1);
        this.engine.playerObj.position.set(pStart.x, 5, pStart.z);
        this.engine.playerObj.visible = true;
        this.engine.tweens.add(this.engine.playerObj.position, { y: 0.1 }, 0.6, Easing.easeOutBounce, () => {
            if (this.selfTestActive) return;
            GameState.phase = 'EXPLORING';
            GameState.updateUI();
            this.refreshAutoPath();
            this.exploreNext();
        });
    }

    exploreNext() {
        if (this.selfTestActive) return;
        if (GameState.phase !== 'EXPLORING') return;
        if (this.path.length === 0) {
            this.refreshAutoPath();
            if (this.path.length === 0) return;
        }

        const nextNode = this.path[0];
        const nextCell = this.grid[nextNode.r][nextNode.c];

        if (nextCell.entity === 'monster') {
            const entityObj = this.engine.entities.find((entity) => entity.c === nextNode.c && entity.r === nextNode.r);
            if (entityObj) this.startCombatRPG(entityObj, nextNode);
            return;
        }

        this.path.shift();
        const targetPos = this.getWorldPos(nextNode.c, nextNode.r);
        this.engine.tweens.add(this.engine.playerObj.position, { x: targetPos.x, z: targetPos.z }, GameState.player.baseSpeed * (this.tempFloorBuffs.moveSpeedMult || 1), Easing.linear, () => {
            this.playerPos.c = nextNode.c;
            this.playerPos.r = nextNode.r;
            this.checkInteraction();
        });
    }

    async checkInteraction() {
        if (this.selfTestActive) return;
        const cell = this.grid[this.playerPos.r][this.playerPos.c];
        if (cell.entity) {
            const type = cell.entity;
            cell.entity = null;
            const entityIndex = this.engine.entities.findIndex((entity) => entity.c === this.playerPos.c && entity.r === this.playerPos.r);
            const entityObj = entityIndex > -1 ? this.engine.entities.splice(entityIndex, 1)[0] : null;

            if (type === 'chest') {
                const reward = 15 * GameState.level;
                GameState.addScore(reward);
                window.soundEngine?.chest();
                if (entityObj) {
                    this.engine.tweens.add(entityObj.mesh.scale, { x: 2, y: 2, z: 2 }, 0.2, Easing.easeOutQuad, () => {
                        this.engine.scene.remove(entityObj.mesh);
                    });
                    this.engine.spawnBurst(entityObj.mesh.position, 0xfacc15, 20, 1.5);
                    this.engine.addFloatingText(`+${reward}`, entityObj.mesh.position, '#facc15');
                }
                await this.sleep(100);
            } else if (type === 'hidden_treasure') {
                const room = this.hiddenRooms.find((item) => item.id === entityObj?.hiddenRoomId);
                if (room) room.cleared = true;
                const reward = Math.floor(this.getHiddenRoomRewardScore(room || { rewardTier: 1 }) * 1.35);
                GameState.addScore(reward);
                window.soundEngine?.chest();
                if (entityObj) {
                    this.engine.tweens.add(entityObj.mesh.scale, { x: 2.2, y: 2.2, z: 2.2 }, 0.2, Easing.easeOutQuad, () => {
                        this.engine.scene.remove(entityObj.mesh);
                    });
                    this.engine.spawnBurst(entityObj.mesh.position, 0xfacc15, 26, 1.7);
                    this.engine.addFloatingText(`+${reward}`, entityObj.mesh.position, '#facc15');
                }
                await this.sleep(120);
            } else if (type === 'hidden_vault') {
                const room = this.hiddenRooms.find((item) => item.id === entityObj?.hiddenRoomId);
                if (room) room.cleared = true;
                const reward = Math.floor(this.getHiddenRoomRewardScore(room || { rewardTier: 4 }) * 2.1);
                GameState.addScore(reward);
                window.soundEngine?.levelClear();
                if (entityObj) {
                    this.engine.tweens.add(entityObj.mesh.scale, { x: 2.5, y: 2.5, z: 2.5 }, 0.22, Easing.easeOutQuad, () => {
                        this.engine.scene.remove(entityObj.mesh);
                    });
                    this.engine.spawnBurst(entityObj.mesh.position, 0xf59e0b, 34, 2.1);
                    this.engine.addFloatingText(`+${reward}`, entityObj.mesh.position, '#f59e0b', true);
                }
                await this.sleep(180);
            } else if (type === 'hidden_event') {
                const room = this.hiddenRooms.find((item) => item.id === entityObj?.hiddenRoomId);
                if (room) room.cleared = true;
                const eventDef = room?.eventDef || this.rollHiddenRoomEvent();
                const healAmount = Math.floor(GameState.player.baseHp * (eventDef.healRatio || 0));
                if (healAmount > 0) GameState.player.currentHp = Math.min(GameState.player.baseHp, GameState.player.currentHp + healAmount);
                const reward = Math.floor(this.getHiddenRoomRewardScore(room || { rewardTier: 2 }) * (eventDef.scoreBonusMult || 0.4));
                if (reward > 0) GameState.addScore(reward);
                if (eventDef.openGates) this.unlockAllHiddenRoomGates();
                if (eventDef.moveSpeedMult) this.tempFloorBuffs.moveSpeedMult = Math.min(this.tempFloorBuffs.moveSpeedMult, eventDef.moveSpeedMult);
                if (eventDef.bonusDamageFlat) this.tempFloorBuffs.bonusDamageFlat += eventDef.bonusDamageFlat;
                if (eventDef.openGates) this.tempFloorBuffs.hiddenBiasFlat = Math.max(this.tempFloorBuffs.hiddenBiasFlat, 0.08);
                window.soundEngine?.upgrade();
                if (entityObj) {
                    this.engine.tweens.add(entityObj.mesh.scale, { x: 2, y: 2, z: 2 }, 0.2, Easing.easeOutQuad, () => {
                        this.engine.scene.remove(entityObj.mesh);
                    });
                    this.engine.spawnBurst(entityObj.mesh.position, parseInt((eventDef.color || '#38bdf8').slice(1), 16), 22, 1.6);
                    this.engine.addFloatingText(eventDef.label, entityObj.mesh.position, eventDef.color || '#38bdf8');
                }
                await this.sleep(160);
            } else if (type === 'merchant_site') {
                const result = this.tryResolveMerchantOffer();
                window.soundEngine?.upgrade();
                if (entityObj) {
                    this.engine.tweens.add(entityObj.mesh.scale, { x: 2, y: 2, z: 2 }, 0.2, Easing.easeOutQuad, () => {
                        this.engine.scene.remove(entityObj.mesh);
                    });
                    this.engine.spawnBurst(entityObj.mesh.position, parseInt(result.color.slice(1), 16), 24, 1.8);
                    this.engine.addFloatingText(result.title, entityObj.mesh.position, result.color, !result.spent);
                    this.engine.addFloatingText(result.subtitle, entityObj.mesh.position.clone().add(new THREE.Vector3(0, 0.32, 0)), '#e2e8f0');
                }
                await this.sleep(180);
            } else if (type === 'end') {
                const reward = 100 * GameState.level;
                GameState.addScore(reward);
                const floorRecovery = Math.max(6, Math.floor(GameState.player.baseHp * 0.16));
                GameState.player.currentHp = Math.min(GameState.player.baseHp, GameState.player.currentHp + floorRecovery);
                GameState.level++;
                window.soundEngine?.levelClear();
                this.engine.addFloatingText('缂佹劒鑳堕悧?', this.engine.playerObj.position, '#10b981', true);
                this.engine.triggerUpgradeEffect();
                setTimeout(() => this.startLevel(), 1200);
                return;
            }
        }
        if (GameState.phase === 'EXPLORING') {
            this.refreshAutoPath();
            this.exploreNext();
        }
    }

    async typeText(text) {
        const el = document.getElementById('rpg-dialogue');
        el.innerText = '';
        for (let i = 0; i < text.length; i++) {
            el.innerText += text[i];
            await this.sleep(24);
        }
    }

