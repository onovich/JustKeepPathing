text-xs font-bold uppercase tracking-[0.22em] text-slate-500">背景音乐合成</div>                     <div class="grid grid-cols-1 gap-3 md:grid-cols-2">                         ${this.checkboxMarkup('启用 BGM', 'enabled', bgm.enabled, 'bgm')}                         ${this.selectMarkup('和弦卷积核', 'kernel', bgm.kernel, Object.entries(BGM_KERNELS).map(([key, info]) => ({ value: key, label: info.label })), 'bgm')}                         ${this.sliderMarkup('音量', 'volume', bgm.volume, 0, 0.5, 0.01, '', 'bgm')}                         ${this.sliderMarkup('速度', 'tempo', bgm.tempo, 50, 180, 1, ' BPM', 'bgm')}                         ${this.sliderMarkup('根音', 'root', bgm.root, 30, 72, 1, ' MIDI', 'bgm')}                         ${this.sliderMarkup('亮度', 'brightness', bgm.brightness, 0.15, 1, 0.01, '', 'bgm')}                         ${this.sliderMarkup('摇摆', 'swing', bgm.swing, 0, 0.45, 0.01, '', 'bgm')}                         ${this.sliderMarkup('音符长度', 'noteLength', bgm.noteLength, 0.2, 1.4, 0.01, 'x', 'bgm')}                         ${this.sliderMarkup('起音', 'attack', bgm.attack, 0.001, 0.2, 0.001, 's', 'bgm')}                         ${this.sliderMarkup('尾音', 'release', bgm.release, 0.05, 1.2, 0.01, 's', 'bgm')}                         ${this.sliderMarkup('立体声扩散', 'stereoSpread', bgm.stereoSpread, 0, 1, 0.01, '', 'bgm')}                         ${this.sliderMarkup('人味抖动', 'humanize', bgm.humanize, 0, 0.12, 0.001, 's', 'bgm')}                         ${this.sliderMarkup('MIDI 失谐', 'detune', bgm.detune, 0, 36, 1, 'c', 'bgm')}                     </div>                 </div>             </div>         `;     }      bindRenderedControls() {         this.controlsEl.querySelectorAll('input, select').forEach((el) => {             const handler = () => {                 this.applyControlValue(el);                 if (el.type === 'range') {                     const valueEl = document.getElementById(`${el.id}-value`);                     if (valueEl) valueEl.innerText = this.formatControlValue(el);                 } else {                     this.render();                 }             };             el.addEventListener(el.tagName === 'SELECT' || el.type === 'checkbox' ? 'change' : 'input', handler);         });     }      formatControlValue(el) {         const value = Number(el.value);         if (el.id.includes('tempo')) return `${Math.round(value)} BPM`;         if (el.id.includes('startFreq') || el.id.includes('endFreq') || el.id.includes('filterCutoff')) return `${Math.round(value)}Hz`;         if (el.id.includes('attack') || el.id.includes('hold') || el.id.includes('release') || el.id.includes('duration') || el.id.includes('humanize')) return `${value.toFixed( el.step && Number(el.step) < 0.01 ? 3 : 2 )}s`;         if (el.id.includes('root')) return `${Math.round(value)} MIDI`;         if (el.id.includes('stepBeats')) return `${value.toFixed(3)} 拍`;         if (el.id.includes('stride') || el.id.includes('accent') || el.id.includes('noteLength')) return `${value.toFixed(2)}x`;         if (el.id.includes('detune')) return `${Math.round(value)}c`;         return value.toFixed(el.step && Number(el.step) < 0.1 ? 2 : 1);     }      applyControlValue(el) {         const group = el.dataset.group;         const field = el.dataset.field;         if (!group || !field) return;         const rawValue = el.type === 'checkbox' ? el.checked : el.value;          if (group === 'oneshot') {             this.workingConfig.sounds[this.currentSoundKey][field] = field === 'waveform' ? rawValue : Number(rawValue);         } else if (group === 'loop') {             this.workingConfig.sounds.footsteps[field] = Number(rawValue);         } else if (group === 'track') {             this.workingConfig.sounds.footsteps.tracks[this.currentTrackIndex][field] = el.type === 'checkbox'                 ? rawValue                 : (field === 'waveform' ? rawValue : Number(rawValue));         } else if (group === 'bgm') {             this.workingConfig.sounds.bgm[field] = el.type === 'checkbox'                 ? rawValue                 : (field === 'kernel' ? rawValue : Number(rawValue));         } else if (group === 'meta' && field === 'trackIndex') {             this.currentTrackIndex = Number(rawValue);         }          this.workingConfig = sanitizeSoundConfig(this.workingConfig);         this.setStatus('已修改未保存');         if (this.soundEngine.currentPreviewKey === this.currentSoundKey && this.soundEngine.isContinuousPreviewActive(this.currentSoundKey)) {             this.soundEngine.updatePreviewConfig(this.currentSoundKey, this.workingConfig);         }         this.updateTransportUi();     }      async handlePreviewToggle() {         await this.soundEngine.unlock();         const def = this.getCurrentSoundDef();         const isContinuous = def.type === 'loop' || def.type === 'bgm';         const isCurrentActive = isContinuous && this.soundEngine.currentPreviewKey === this.currentSoundKey && this.soundEngine.isContinuousPreviewActive(this.currentSoundKey);          if (isCurrentActive && !this.soundEngine.previewPaused) {             this.pausePreview();             return;         }          if (isCurrentActive && this.soundEngine.previewPaused) {             this.soundEngine.resumePreview();             this.setStatus('试听中');             this.updateTransportUi();             return;         }          this.previewCurrent();     }      async previewCurrent() {         await this.soundEngine.unlock();         this.soundEngine.previewSound(this.currentSoundKey, this.workingConfig);         this.setStatus('试听中');         this.updateTransportUi();         this.log(`试听 ${SOUND_EVENT_DEFS[this.currentSoundKey].label}。`);     }      pausePreview() {         this.soundEngine.pausePreview();         this.setStatus('\u5df2\u6682\u505c\u8bd5\u542c');         this.updateTransportUi();     }      stopPreview(updateStatus = true) {         this.soundEngine.stopPreview();         if (updateStatus) this.setStatus('已停止试听');         this.updateTransportUi();     }      readSavedConfig() {         this.stopPreview(false);         this.workingConfig = this.soundEngine.readStoredSoundConfig();         this.setStatus('已读取当前生产配置');         this.render();         this.log('已重新载入已保存的音效配置。');     }      resetToBackup() {         this.stopPreview(false);         this.workingConfig = cloneSoundConfig();         this.setStatus('已重置到备份配置');         this.render();         this.log('工作副本已重置到默认备份配置。');     }      saveToRuntime() {         this.stopPreview(false);         this.workingConfig = sanitizeSoundConfig(this.workingConfig);         this.soundEngine.saveSoundConfig(this.workingConfig);         this.setStatus('已保存到生产环境');         this.log('音效配置已保存，实时游戏音效与 BGM 已更新。');     } }  
window.onload = () => {
    window.soundEngine = new SoundEngine();
    const unlockAudio = () => window.soundEngine.unlock();
    window.addEventListener('pointerdown', unlockAudio, { passive: true });
    window.addEventListener('keydown', unlockAudio);
    const settingsButton = document.getElementById('btn-settings');
    const settingsPanel = document.getElementById('settings-panel');
    const volumeSlider = document.getElementById('slider-volume');
    const volumeValue = document.getElementById('val-volume');

    const syncVolumeUI = () => {
        const percent = Math.round(window.soundEngine.volume * 100);
        volumeSlider.value = String(percent);
        volumeValue.innerText = `${percent}%`;
    };

    settingsButton.addEventListener('click', async (event) => {
        event.stopPropagation();
        await window.soundEngine.unlock();
        settingsPanel.classList.toggle('hidden');
    });

    settingsPanel.addEventListener('click', (event) => {
        event.stopPropagation();
    });

    document.addEventListener('click', () => {
        settingsPanel.classList.add('hidden');
    });

    volumeSlider.addEventListener('input', async () => {
        await window.soundEngine.unlock();
        window.soundEngine.setVolume(Number(volumeSlider.value) / 100);
        syncVolumeUI();
        window.soundEngine.beep({ freq: 520, slideTo: 700, duration: 0.08, volume: 0.035, type: 'triangle' });
    });

    syncVolumeUI();
    window.engine = new VisualEngine();
    window.modelEditor = new ModelEditor(window.engine);
    window.soundEditor = new SoundEditor(window.soundEngine);
    window.gameController = new GameController(window.engine);
    GameState.updateUI();

    const selfTestMode = window.location.hash.replace('#', '');
    if (selfTestMode === 'selftest-player' || selfTestMode === 'selftest-chest') {
        const mode = selfTestMode === 'selftest-chest' ? 'chest' : 'player';
        const selfTestTimer = setInterval(() => {
            if (window.gameController) {
                try {
                    window.gameController.runOcclusionSelfTest(mode);
                    clearInterval(selfTestTimer);
                } catch (error) {
                    console.warn('Self-test scene not ready yet:', error);
                }
            }
        }, 250);
    }
};
</script>
