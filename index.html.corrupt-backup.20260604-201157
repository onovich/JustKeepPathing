                ? `闁诡剦浜炴晶鍧楀即閺夋埈鍟囬柡鍕尭閸ゎ參鎮崇敮顔剧Boss 闁告垼娅ｉ獮鍥ь潡閸屾粌鑺?${Math.round(this.getBossFloorChance() * 100)}%`
                : '闁诡剦浜炴晶鍧楀即閺夋埈鍟囬柡鍕尭閸ゎ參鎮崇敮顔剧闁告娲ら崺?Lv.4 閻熸瑱缍侀弨?Boss';
        }
        const hiddenDesc = document.getElementById('desc-hidden');
        if (hiddenDesc) {
            hiddenDesc.innerText = `閻庨潧妫楅濠氬礄閾忕懓绠?+${Math.round(this.getHiddenRoomSpawnBonus() * 100)}%闁挎稑鐭侀崵婊堝礉閵娧呮悘閻?+${Math.round(this.getHiddenRoomDiversionBonus() * 100)}%`;
        }
    }
};

window.GameState = GameState;

const Easing = {
    linear: (t) => t,
    easeOutQuad: (t) => t * (2 - t),
    easeOutBack: (t) => {
        const c1 = 1.70158;
        const c3 = c1 + 1;
        return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2);
    },
    easeOutBounce: (t) => {
        const n1 = 7.5625;
        const d1 = 2.75;
        if (t < 1 / d1) return n1 * t * t;
        if (t < 2 / d1) { t -= 1.5 / d1; return n1 * t * t + 0.75; }
        if (t < 2.5 / d1) { t -= 2.25 / d1; return n1 * t * t + 0.9375; }
        t -= 2.625 / d1;
        return n1 * t * t + 0.984375;
    },
    easeOutElastic: (t) => {
        const c4 = (2 * Math.PI) / 3;
        return t === 0 ? 0 : t === 1 ? 1 : Math.pow(2, -10 * t) * Math.sin((t * 10 - 0.75) * c4) + 1;
    }
};

class TweenManager {
    constructor() {
        this.tweens = [];
    }

    add(obj, props, duration, easing = Easing.linear, onComplete = null) {
        const startProps = {};
        for (const key in props) startProps[key] = obj[key];
        this.tweens.push({ obj, startProps, targetProps: props, duration, time: 0, easing, onComplete });
    }

    update(dt) {
        for (let i = this.tweens.length - 1; i >= 0; i--) {
            const tween = this.tweens[i];
            tween.time += dt;
            const progress = Math.min(tween.time / tween.duration, 1);
            const eased = tween.easing(progress);
            for (const key in tween.targetProps) {
                tween.obj[key] = tween.startProps[key] + (tween.targetProps[key] - tween.startProps[key]) * eased;
            }
            if (progress === 1) {
                if (tween.onComplete) tween.onComplete();
                this.tweens.splice(i, 1);
            }
        }
    }
}

class VisualEngine {
    constructor() {
        this.container = document.getElementById('game-container');
        this.canvas = document.getElementById('webgl-canvas');
        this.textContainer = document.getElementById('floating-text-container');

        const w = Math.max(300, this.container.clientWidth);
        const h = Math.max(300, this.container.clientHeight);

        this.scene = new THREE.Scene();
        this.scene.background = new THREE.Color(0x000000);
        this.camera = new THREE.PerspectiveCamera(50, w / h, 0.1, 1000);
        this.camera.layers.enable(1);
        this.cameraTarget = new THREE.Vector3();

        this.renderer = new THREE.WebGLRenderer({ canvas: this.canvas, antialias: true });
        this.renderer.setSize(w, h);
        this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        this.composer = new EffectComposer(this.renderer);
        this.composer.addPass(new RenderPass(this.scene, this.camera));
        this.glitchPass = new GlitchPass();
        this.glitchPass.goWild = false;
        this.glitchPass.enabled = false;
        this.composer.addPass(this.glitchPass);
        this.composer.addPass(new OutputPass());
        this.playerMaskMaterial = new THREE.MeshBasicMaterial({ color: 0xffffff });
        this.playerOcclusionTarget = new THREE.WebGLRenderTarget(w, h, {
            minFilter: THREE.LinearFilter,
            magFilter: THREE.LinearFilter,
            format: THREE.RGBAFormat,
            depthBuffer: true,
            stencilBuffer: false
        });
        this.playerOcclusionTarget.texture.generateMipmaps = false;
        this.playerOcclusionTarget.depthTexture = new THREE.DepthTexture(w, h, THREE.UnsignedShortType);
        this.playerOcclusionTarget.depthTexture.format = THREE.DepthFormat;

        this.tweens = new TweenManager();
        this.clock = new THREE.Clock();
        this.entities = [];
        this.particles = [];
        this.floatingTexts = [];
        this.trauma = 0;
        this.motionTime = 0;
        this.lastPlayerAudioPos = null;
        this.playerRevealRadius = 0.58;
        this.occluders = [];
        this.occluderLookup = new Map();
        this.raycaster = new THREE.Raycaster();
        this.appearanceConfig = this.readStoredAppearanceConfig();

        this.materials = {
            floor: new THREE.MeshBasicMaterial({ color: 0x1e293b }),
            wallBox: new THREE.MeshBasicMaterial({ color: 0x020617 }),
            wallEdge: new THREE.LineBasicMaterial({ color: 0x000000, linewidth: 2 }),
            playerMain: new THREE.MeshBasicMaterial({ color: 0x22d3ee }),
            playerAccent: new THREE.MeshBasicMaterial({ color: 0x93c5fd }),
            playerCabin: new THREE.MeshBasicMaterial({ color: 0xe0f2fe }),
            playerShadow: new THREE.MeshBasicMaterial({ color: 0x0f172a }),
            chest: new THREE.MeshBasicMaterial({ color: 0xfacc15 }),
            chestDark: new THREE.MeshBasicMaterial({ color: 0x854d0e }),
            end: new THREE.MeshBasicMaterial({ color: 0x10b981 })
        };

        this.setupPlayer();
        window.addEventListener('resize', () => this.resize());
        this.resize();
        this.animate = this.animate.bind(this);
