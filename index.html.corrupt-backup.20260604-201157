    buildCombatProfile(enemyObj) {
        const data = enemyObj.enemyData;
        const linearScale = data.boss ? 1 + (GameState.level - 1) * 0.34 : 1 + (GameState.level - 1) * 0.18;
        const curveScale = Math.pow(data.boss ? 1.1 : 1.06, Math.max(0, GameState.level - 1));
        return {
            name: data.name,
            intro: data.intro,
            attackVerb: data.attackVerb,
            reward: Math.floor(data.reward * (1 + GameState.level * 0.18)),
            maxHp: Math.floor(data.baseHp * linearScale * curveScale),
            atk: Math.floor(data.baseAtk * linearScale),
            boss: !!data.boss,
            color: data.color
        };
    }

    async startCombatRPG(enemyObj, enemyNode) {
        if (this.selfTestActive) return;
        GameState.phase = 'COMBAT';
        GameState.updateUI();
        this.currentEnemy = enemyObj;

        const profile = this.buildCombatProfile(enemyObj);
        let enemyHp = profile.maxHp;
        const enemyMesh = enemyObj.mesh;
        const playerMesh = this.engine.playerObj;
        enemyMesh.lookAt(playerMesh.position);
        playerMesh.lookAt(enemyMesh.position);

        this.showCombatUI();

        this.updateRPG_HP(enemyHp, profile.maxHp, enemyObj);

        await this.sleep(profile.boss ? 900 : 600);
        if (profile.boss) window.soundEngine?.bossIntro();
        await this.typeText(profile.intro);
        await this.sleep(profile.boss ? 900 : 700);

        const dir = new THREE.Vector3().subVectors(enemyMesh.position, playerMesh.position).normalize();
        const dashDist = profile.boss ? 0.82 : 0.65;

        while (enemyHp > 0 && GameState.player.currentHp > 0) {
            await this.typeText(`闁靛棙鍔楃敮铏光偓鐟板濞堟垿宕堕悙鍙夊€ら柕鍡樺灴椤ワ絿鍠婇悢璺虹槣闁绘劦鍣ｉ弨锝団偓?${profile.name}闁挎稐姊?;
            await this.sleep(320);

            const damage = Math.floor((GameState.player.baseAtk + (this.tempFloorBuffs.bonusDamageFlat || 0)) * (0.84 + Math.random() * 0.42) * (profile.boss ? 0.92 : 1));
            const origPos = playerMesh.position.clone();
            const dashPos = origPos.clone().add(dir.clone().multiplyScalar(dashDist));

            this.engine.tweens.add(playerMesh.position, { x: dashPos.x, z: dashPos.z }, 0.1, Easing.easeOutQuad, () => {
                this.engine.shake(profile.boss ? 0.42 : 0.3);
                window.soundEngine?.enemyHit(profile.boss);
                this.engine.addFloatingText(damage.toString(), enemyMesh.position, '#38bdf8', true);
                this.engine.spawnBurst(enemyMesh.position, profile.color, profile.boss ? 18 : 12, profile.boss ? 2.1 : 1.5);
                this.engine.tweens.add(enemyMesh.scale, { x: 1.35, y: 0.55, z: 1.35 }, 0.1, Easing.linear, () => {
                    this.engine.tweens.add(enemyMesh.scale, { x: 1, y: 1, z: 1 }, 0.22, Easing.easeOutElastic);
                });
                this.engine.tweens.add(playerMesh.position, { x: origPos.x, z: origPos.z }, 0.2, Easing.easeOutQuad);
            });

            await this.sleep(300);
            enemyHp -= damage;
            this.updateRPG_HP(enemyHp, profile.maxHp, enemyObj);
            await this.typeText(`闁告稒鍨濋懙鎴︽晬?{profile.name} 闁告瑦顨呴崺灞剧?${damage} 闁绘劙鈧稒绺洪悗鍦仺閳ь兛绻?;
            await this.sleep(620);

            if (enemyHp <= 0) break;

            await this.typeText(`闁?{profile.name} 闁汇劌瀚ú鏍触閸稈鍋撻幋锕€娅為柡鈧?${profile.attackVerb}闁挎稐姊?;
            await this.sleep(360);

            const enemyDamage = Math.floor(profile.atk * (0.82 + Math.random() * 0.38));
            const enemyOrigPos = enemyMesh.position.clone();
            const enemyDashPos = enemyOrigPos.clone().sub(dir.clone().multiplyScalar(dashDist));

            this.engine.tweens.add(enemyMesh.position, { x: enemyDashPos.x, z: enemyDashPos.z }, profile.boss ? 0.18 : 0.15, Easing.easeOutQuad, () => {
                this.engine.glitch(profile.boss ? 220 : 150);
                this.engine.shake(profile.boss ? 0.8 : 0.6);
                window.soundEngine?.playerHit(profile.boss);
                this.engine.addFloatingText(`-${enemyDamage}`, playerMesh.position, '#ef4444', true);
                this.engine.spawnBurst(playerMesh.position, 0xef4444, profile.boss ? 22 : 15, profile.boss ? 2.8 : 2);
                this.engine.tweens.add(this.engine.playerMesh.scale, { x: 1.24, y: 0.68, z: 1.24 }, 0.1, Easing.linear, () => {
                    this.engine.tweens.add(this.engine.playerMesh.scale, { x: 1, y: 1, z: 1 }, 0.22, Easing.easeOutElastic);
                });
                this.engine.tweens.add(enemyMesh.position, { x: enemyOrigPos.x, z: enemyOrigPos.z }, 0.24, Easing.easeOutQuad);
            });

            await this.sleep(320);
            GameState.player.currentHp -= enemyDamage;
            this.updateRPG_HP(enemyHp, profile.maxHp, enemyObj);
            await this.typeText(`閻犫偓閿曗偓閹诧繝鏁嶆担鍝勮礋閻庣鍩栧畷顖涘緞閸欐鍟?${enemyDamage} 闁绘劕婀遍弫鎾诲川閽樺鍋撶涵椋庣＜`);
