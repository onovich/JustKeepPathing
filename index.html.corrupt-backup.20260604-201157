    <style>
        body { 
            background-color: #000; 
            color: #f8fafc; 
            overflow: hidden; 
            user-select: none;
            -webkit-user-select: none;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        #game-container { touch-action: none; position: relative; }

        #floating-text-container {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; overflow: hidden;
        }
        .floating-text {
            position: absolute; transform: translate(-50%, -50%); font-weight: 900;
            text-shadow: 0 2px 0 #000, 2px 0 0 #000, 0 -2px 0 #000, -2px 0 0 #000;
            will-change: transform, opacity;
        }

        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: #0f172a; }
        ::-webkit-scrollbar-thumb { background: #38bdf8; border-radius: 2px; }
        .upgrade-btn { transition: all 0.1s cubic-bezier(0.4, 0, 0.2, 1); }
        .upgrade-btn:active { transform: scale(0.96); filter: brightness(1.2); }
        .settings-slider { accent-color: #22d3ee; }
        .settings-panel-enter { animation: settings-pop 0.18s ease-out; transform-origin: top right; }
        .editor-surface { background: linear-gradient(180deg, rgba(15,23,42,0.98), rgba(2,6,23,0.98)); }
        .editor-canvas-wrap {
            background:
                radial-gradient(circle at 20% 20%, rgba(34,211,238,0.12), transparent 24%),
                radial-gradient(circle at 80% 15%, rgba(250,204,21,0.1), transparent 22%),
                linear-gradient(180deg, rgba(15,23,42,1), rgba(3,7,18,1));
        }
        .editor-grid {
            background-image:
                linear-gradient(rgba(148,163,184,0.08) 1px, transparent 1px),
                linear-gradient(90deg, rgba(148,163,184,0.08) 1px, transparent 1px);
            background-size: 32px 32px;
        }

        /* RPG UI 濞戞挻鎸搁惈姗€宕濋妸褎鏆?*/
        .typewriter::after {
            content: '|';
            animation: blink 1s step-end infinite;
        }
        @keyframes blink { 50% { opacity: 0; } }
        @keyframes settings-pop {
            from { opacity: 0; transform: translateY(-6px) scale(0.96); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        
        .hp-bar-fill { transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1); }

        @media (max-width: 767px) {
            #game-container {
                min-height: 100dvh;
                border-right: 0;
                border-bottom: 0;
            }

            #ui-container {
                position: fixed;
                left: 0;
                right: 0;
                bottom: 0;
                z-index: 45;
                height: auto;
                width: auto;
                background: linear-gradient(180deg, rgba(15, 23, 42, 0.9), rgba(2, 6, 23, 0.96));
                backdrop-filter: blur(16px);
                box-shadow: 0 -18px 36px rgba(0, 0, 0, 0.35);
                border-top: 1px solid rgba(51, 65, 85, 0.9);
            }

            #ui-titlebar {
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 10px 16px;
                border-bottom: 1px solid rgba(30, 41, 59, 0.95);
                background: rgba(30, 41, 59, 0.78);
            }

            #ui-titlebar h1 {
                font-size: 1rem;
                line-height: 1.1;
            }

            #ui-mobile-dock {
                display: flex;
                align-items: stretch;
                gap: 12px;
                overflow-x: auto;
                overflow-y: hidden;
                padding: 12px 14px calc(12px + env(safe-area-inset-bottom));
                background: transparent;
                scrollbar-width: none;
                -webkit-overflow-scrolling: touch;
                scroll-snap-type: x proximity;
            }

            #ui-mobile-dock::-webkit-scrollbar {
                display: none;
            }

            #ui-mobile-dock > :not([hidden]) ~ :not([hidden]),
            #upgrade-strip > :not([hidden]) ~ :not([hidden]) {
                margin-top: 0;
            }

            #ui-score-card {
                flex: 0 0 124px;
                min-width: 124px;
                margin: 0;
                padding: 12px;
                border-radius: 18px;
                scroll-snap-align: start;
            }

            #ui-score-card #ui-score {
                font-size: 1.5rem;
                line-height: 1;
            }

            #upgrade-strip {
                display: flex;
                align-items: stretch;
                gap: 12px;
                margin: 0;
                padding: 0;
                flex: 0 0 auto;
            }

            #upgrade-strip > .upgrade-btn {
                flex: 0 0 220px;
                width: 220px;
                min-height: 92px;
                margin: 0;
                padding: 12px 14px;
                border-radius: 18px;
                align-items: flex-start;
                scroll-snap-align: start;
            }

            #upgrade-strip > .upgrade-btn > div:first-child {
                min-width: 0;
            }

            #upgrade-strip > .upgrade-btn > div:first-child .font-bold {
                font-size: 1rem;
                line-height: 1.15;
            }

            #upgrade-strip > .upgrade-btn > div:first-child .text-\[10px\] {
                font-size: 0.72rem;
                line-height: 1.2;
            }

            #upgrade-strip > .upgrade-btn > div:last-child {
                flex: 0 0 auto;
                align-self: center;
            }

            #upgrade-strip > .upgrade-btn > div:last-child .text-sm {
                font-size: 1.5rem;
                line-height: 1;
            }

            #rpg-combat-ui {
                padding: 12px;
            }

            #rpg-combat-ui > div:first-child {
                margin-top: 56px;
            }

            #rpg-combat-ui > div:first-child > div {
                width: 124px;
                padding: 8px 10px;
            }

            #rpg-combat-ui > div:last-child {
                margin-bottom: calc(148px + env(safe-area-inset-bottom));
            }

            #rpg-dialogue {
                font-size: 0.92rem;
                line-height: 1.45;
                min-height: 1.45rem;
            }
        }
    </style>
</head>
