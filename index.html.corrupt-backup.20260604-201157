        statusSpan.innerText = statusMap[this.phase] || 'Idle';

        if (this.phase === 'COMBAT') {
            statusBox.className = 'bg-red-900/95 px-4 py-2 rounded-lg border-2 border-red-500 text-sm shadow-[0_4px_0_rgba(153,27,27,1)] animate-pulse';
            statusSpan.className = 'text-white font-bold ml-1';
        } else {
            statusBox.className = 'bg-slate-900/95 px-4 py-2 rounded-lg border-2 border-slate-700 text-sm shadow-[0_4px_0_rgba(0,0,0,0.5)]';
            statusSpan.className = 'text-emerald-400 font-bold ml-1';
        }

        document.getElementById('ui-score').innerText = Math.floor(this.score);
        ['speed', 'atk', 'hp', 'chest', 'size', 'hidden', 'monster'].forEach((id) => {
            const lv = this.player[`lv${id.charAt(0).toUpperCase() + id.slice(1)}`] || this.maze[`lv${id.charAt(0).toUpperCase() + id.slice(1)}`];
            const isSizeMaxed = id === 'size' && this.isMazeSizeMaxed();
            const cost = isSizeMaxed ? null : this.costs[id]();
            document.getElementById(`val-${id}`).innerText = id === 'size'
                ? `${this.getMazeSide()}x${this.getMazeSide()}`
