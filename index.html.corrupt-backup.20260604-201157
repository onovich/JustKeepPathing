        let best = null;

        this.previewModel.traverse((child) => {
            if (child.userData?.editorMeta?.kind !== 'line') return;
            const positions = child.geometry?.getAttribute('position');
            if (!positions) return;

            for (let i = 0; i < positions.count; i += 2) {
                p1.fromBufferAttribute(positions, i).applyMatrix4(child.matrixWorld);
                p2.fromBufferAttribute(positions, i + 1).applyMatrix4(child.matrixWorld);
                const distSq = ray.distanceSqToSegment(p1, p2, rayPoint, segPoint);
                if (distSq > maxDistSq) continue;
                const hitDistance = ray.origin.distanceTo(segPoint);
                if (!best || hitDistance < best.distance) {
                    const meta = child.userData.editorMeta;
                    best = {
                        kind: 'line',
                        object: child,
                        index: i / 2,
                        distance: hitDistance,
                        assetKey: meta.assetKey,
                        partKey: meta.partKey,
                        defaultColor: meta.defaultColor
                    };
