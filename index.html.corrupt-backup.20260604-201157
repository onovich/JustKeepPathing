            document.getElementById(`cost-${id}`).innerText = isSizeMaxed ? 'MAX' : cost;
            const btn = document.getElementById(`btn-up-${id}`);
            if (!isSizeMaxed && this.score >= cost) btn.classList.remove('opacity-50', 'grayscale');
            else btn.classList.add('opacity-50', 'grayscale');
        });

        const sizeDesc = document.getElementById('desc-size');
        if (sizeDesc) {
            const sizeFactor = this.getMazeSizeFactor();
            sizeDesc.innerText = this.isMazeSizeMaxed()
                ? `鐟滅増鎸告晶?${this.getMazeSide()}x${this.getMazeSide()}闁挎稑鑻崙锛勭磼韫囨梹笑闁哄牃鍋撳鍫嗗棛纰冮悗鍦袱
                : `鐟滅増鎸告晶?${this.getMazeSide()}x${this.getMazeSide()}闁挎稑鏈埀顒傜帛閺佸綊鎯勬繝鍕唺 ${Math.round(sizeFactor * 100)}%`;
        }

        const monsterDesc = document.getElementById('desc-monster');
        if (monsterDesc) {
